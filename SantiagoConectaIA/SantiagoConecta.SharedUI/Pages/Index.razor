<section class="section colored" id="contacto" style="background-color: #f8f9fa;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="center-heading">
                    <h2 class="section-title" style="color: #880e4f;">Buzón Ciudadano</h2>
                </div>
            </div>
            <div class="offset-lg-3 col-lg-6">
                <div class="center-text">
                    <p>Tu opinión es importante para nosotros. Utiliza este espacio para enviarnos tus comentarios, sugerencias o reportes directos al H. Ayuntamiento.</p>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-4 col-md-6 col-sm-12">
                <h5 class="margin-bottom-30" style="color: #880e4f;">Información de Contacto</h5>
                <div class="contact-text">
                    <p>
                        <strong>Dirección:</strong><br>
                        Calle Riva Palacio #19, Colonia Centro,<br>
                        Santiago Papasquiaro, Durango.
                    </p>
                    <p>
                        <strong>Teléfono Oficial:</strong><br>
                        674 86 2 18 46
                    </p>
                    <p><strong>Atención Ciudadana:</strong> Lunes a Viernes de 8:00 a 15:00 hrs.</p>
                </div>
            </div>
            <div class="col-lg-8 col-md-6 col-sm-12">
                <div class="contact-form" style="background: white; padding: 30px; border-radius: 16px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
                    @if (!string.IsNullOrEmpty(_successMessage))
                    {
                        <div class="alert alert-success" role="alert" style="border-radius: 12px; padding: 15px; margin-bottom: 20px; background-color: #d4edda; color: #155724; border: 1px solid #c3e6cb;">
                            <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Class="mr-2" /> @_successMessage
                        </div>
                    }
                    @if (!string.IsNullOrEmpty(_errorMessage))
                    {
                        <div class="alert alert-danger" role="alert" style="border-radius: 12px; padding: 15px; margin-bottom: 20px; background-color: #f8d7da; color: #721c24; border: 1px solid #f5c6cb;">
                            <MudIcon Icon="@Icons.Material.Filled.Error" Class="mr-2" /> @_errorMessage
                        </div>
                    }
                    <EditForm Model="@contactModel" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <div class="row">
                            <div class="col-lg-6 col-md-12 col-sm-12 mb-3">
                                <MudTextField @bind-Value="contactModel.Name" Label="Nombre Completo" Variant="Variant.Outlined" Required="true" />
                            </div>
                            <div class="col-lg-6 col-md-12 col-sm-12 mb-3">
                                <MudTextField @bind-Value="contactModel.Email" Label="Correo Electrónico" Variant="Variant.Outlined" Required="true" />
                            </div>
                            <div class="col-lg-6 col-md-12 col-sm-12 mb-3">
                                <MudTextField @bind-Value="contactModel.Phone" Label="Teléfono (opcional)" Variant="Variant.Outlined" />
                            </div>
                            <div class="col-lg-6 col-md-12 col-sm-12 mb-3">
                                <MudSelect T="string" @bind-Value="contactModel.Category" Label="Categoría" Variant="Variant.Outlined" Required="true">
                                    <MudSelectItem Value="@("Queja")" />
                                    <MudSelectItem Value="@("Sugerencia")" />
                                    <MudSelectItem Value="@("Reporte")" />
                                    <MudSelectItem Value="@("Solicitud")" />
                                    <MudSelectItem Value="@("Otro")" />
                                </MudSelect>
                            </div>
                            <div class="col-lg-12 mb-3">
                                <MudTextField @bind-Value="contactModel.Message" Label="Tu Mensaje, Queja o Sugerencia" Variant="Variant.Outlined" Lines="5" Required="true" />
                            </div>
                            <div class="col-lg-12">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="border-radius: 30px;" Disabled="@_isSubmitting">
                                    @if (_isSubmitting)
                                    {
                                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                                        @("Enviando...")
                                    }
                                    else
                                    {
                                        <MudIcon Icon="@Icons.Material.Filled.Send" Class="mr-2" />
                                        @("Enviar Mensaje")
                                    }
                                </MudButton>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
