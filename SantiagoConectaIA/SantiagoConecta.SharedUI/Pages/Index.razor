                            <div class="glass-content-panel">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="category-pill-neon">
                                        <MudIcon Icon="@Icons.Material.Filled.Explore" Size="Size.Small" Class="mr-2" />
                                        @dato.nvchCategoria
                                    </div>
                                </div>
                                
                                <h3 class="display-title">@dato.nvchTitulo</h3>
                                
                                <div class="divider-glow"></div>
                                
                                <p class="lead-desc">@dato.nvchDescripcionCorta</p>
                                <p class="body-desc">@dato.nvchContenidoDetallado</p>
                                
