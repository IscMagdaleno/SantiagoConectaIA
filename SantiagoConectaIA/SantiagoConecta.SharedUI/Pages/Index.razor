        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(216, 27, 96, 0.2) !important;
    }
    
    /* Hero Animations */
    .hero-animated-bg {
        background: linear-gradient(-45deg, #880e4f, #d81b60, #4a148c, #c2185b);
