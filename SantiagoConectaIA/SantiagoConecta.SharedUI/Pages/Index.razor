@page "/"
@using SantiagoConecta.SharedUI.Data
@using SantiagoConectaIA.Share.PostModels.BuzonCiudadanoModule
@using SantiagoConectaIA.Share.Objects.NoticiasModule
@using SantiagoConectaIA.Share.PostModels.NoticiasModule
@using SantiagoConectaIA.Share.Objects.EventosModulo
@using SantiagoConectaIA.Share.PostClass.EventosModulo
@using SantiagoConectaIA.Share.Objetos.InformacionLocalModulo
@using SantiagoConectaIA.Share.PostClass.InformacionLocalModulo
@using Microsoft.Extensions.Localization
@inject NavigationManager NavManager
@inject IStringLocalizer<App> Localizer
@inject IJSRuntime JS
@inject Data_BuzonCiudadano _dataBuzon
@inject Data_Noticias dataNoticias
@inject Data_Eventos dataEventos
@inject ISnackbar Snackbar
@inject Data_InformacionLocal dataInformacionLocal

<PageTitle>Santiago Conecta - Inicio</PageTitle>

<!-- ***** Hero Section (Bienvenida) ***** -->
<div class="welcome-area js-dynamic-bg" id="welcome" style="min-height: 100vh; display: flex; align-items: center; position: relative; overflow: hidden; padding-top: 80px;">
    
    <!-- Efecto Glow que sigue al cursor -->
    <div class="hero-glow" id="hero-glow"></div>

    <!-- Sistema interactivo de partículas en Canvas -->
    <canvas id="hero-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; opacity: 0.8;"></canvas>

    <div class="header-text" style="width: 100%; position: relative !important; top: auto !important; transform: none !important; z-index: 5; padding-bottom: 12vh;">
        <div class="container">
            <div class="row">
                <div class="col-xl-8 col-lg-10 col-md-12 col-sm-12 mx-auto text-center" style="display: flex; flex-direction: column; align-items: center;">
                    
                    <!-- Slider Glass -->
                    <MudCarousel Class="mud-width-full" Style="height:180px; max-width:600px; margin-top: clamp(20px, 4vh, 40px); margin-bottom:20px; border-radius:28px; box-shadow:0 8px 32px rgba(0,0,0,0.15); background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.25);" ShowArrows="false" ShowBullets="false" AutoCycle="true" EnableSwipeGesture="true" TData="object">
                        
                        <!-- Slide WhatsApp -->
                        <MudCarouselItem Transition="Transition.Slide">
                            <div style="height: 100%; display: flex; align-items: center; justify-content: center; padding: 12px 24px; gap: 16px; cursor: pointer; text-align: left;" @onclick="OpenWhatsAppInfo">
                                <MudIcon Icon="@Icons.Material.Filled.Chat" Style="font-size: 50px; color: #ffb4a2; flex-shrink: 0;" />
                                <div style="flex-grow: 1; overflow: hidden;">
                                    <div style="background: linear-gradient(135deg, #ffb4a2, #ff8a65); color: #880e4f; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; display: inline-block; margin-bottom: 6px;">
                                        WhatsApp IA
                                    </div>
                                    <MudText Typo="Typo.body1" Style="color: white; font-weight: 600; font-size: 1rem; line-height: 1.3; text-shadow: 0 1px 2px rgba(0,0,0,0.2); display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">¡Resuelve tus dudas al instante con nuestro asistente virtual!</MudText>
                                </div>
                            </div>
                        </MudCarouselItem>

                        <!-- Slide Noticias -->
                        @if (latestNoticia != null)
                        {
                            <MudCarouselItem Transition="Transition.Slide">
                                <div style="height: 100%; display: flex; align-items: center; justify-content: center; padding: 12px 24px; gap: 16px; cursor: pointer; text-align: left;" @onclick='() => NavManager.NavigateTo($"/noticias/{latestNoticia.iIdNoticia}")'>
                                    <MudIcon Icon="@Icons.Material.Filled.Article" Style="font-size: 50px; color: #ffb4a2; flex-shrink: 0;" />
                                    <div style="flex-grow: 1; overflow: hidden;">
                                        <div style="background: linear-gradient(135deg, #ffb4a2, #ff8a65); color: #880e4f; padding: 4px 12px; border-radius: 20px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; display: inline-block; margin-bottom: 6px; max-width: 100%; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                            @(latestNoticia.Categoria?.vchNombre ?? "Noticia")
                                        </div>
                                        <MudText Typo="Typo.body1" Style="color: white; font-weight: 600; font-size: 1rem; line-height: 1.3; text-shadow: 0 1px 2px rgba(0,0,0,0.2); display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis;">@latestNoticia.vchTitulo</MudText>
                                    </div>
                                </div>
                            </MudCarouselItem>
                        }
                    </MudCarousel>

                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="font-size: 50px; color: #ffb4a2; margin-bottom: 10px; animation: float 3s ease-in-out infinite;" />
                    <h1 style="color: white; font-weight: 800; font-size: clamp(2rem, 8vw, 3.5rem); line-height: 1.2; margin-bottom: 20px; text-shadow: 0 4px 20px rgba(0,0,0,0.3); letter-spacing: -1px;">
                        Bienvenido a <span style="color: #ffb4a2;">Santiago Conecta</span>
                    </h1>
                    <p style="color: rgba(255, 255, 255, 0.95); font-size: clamp(1rem, 4vw, 1.25rem); margin-bottom: 40px; font-weight: 300; line-height: 1.6; text-shadow: 0 2px 10px rgba(0,0,0,0.2);">
                        Tu Asistente Virtual Inteligente 24/7. Santiago Conecta pone a tu disposición esta herramienta de nueva generación para resolver tus dudas, consultar trámites y evitar filas.
                    </p>
                    <button class="main-button-slider hero-btn" @onclick="OpenChatbot">
                        <i class="fa fa-comments mr-2"></i> Conversar con la IA
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Ondas Animadas SVG -->
    <div class="waves-container">
        <svg class="waves" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
            <defs>
                <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
            </defs>
            <g class="parallax">
                <use xlink:href="#gentle-wave" x="48" y="0" fill="rgba(255,255,255,0.7" />
                <use xlink:href="#gentle-wave" x="48" y="3" fill="rgba(255,255,255,0.5)" />
                <use xlink:href="#gentle-wave" x="48" y="5" fill="rgba(255,255,255,0.3)" />
                <use xlink:href="#gentle-wave" x="48" y="7" fill="#ffffff" />
            </g>
        </svg>
    </div>
</div>
<!-- ***** Hero Section End ***** -->

<!-- ***** Sección de Destacados (Noticias y Eventos) ***** -->
<section class="section" style="padding-top: 40px; position: relative; z-index: 10;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="center-heading mb-4">
                    <h2 class="section-title" style="color: #880e4f; font-weight: 800;">Lo Más Destacado</h2>
                </div>
            </div>
        </div>
        <div class="row">
            <!-- Slider Destacados -->
            <div class="col-lg-6 mb-4">
                <div class="destacado-card js-dynamic-bg custom-slider" style="border-radius: 20px; overflow: hidden; height: 100%; min-height: 380px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); position: relative;">
                    <MudCarousel Class="mud-width-full" Style="height:100%; min-height: 380px; width: 100%;" ShowArrows="true" ShowBullets="true" AutoCycle="true" EnableSwipeGesture="true" TData="object">
                        
                        <!-- Slide 1: WhatsApp -->
                        <MudCarouselItem Transition="Transition.Slide">
                            <div style="height: 100%; display: flex; flex-direction: column; justify-content: center; padding: 40px; position: relative; z-index: 2;">
                                <span class="badge" style="background: white; color: #d81b60; padding: 8px 15px; border-radius: 20px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; display: inline-block; width: max-content; box-shadow: 0 4px 10px rgba(0,0,0,0.2);">¡Nuevo!</span>
                                <MudIcon Icon="@Icons.Material.Filled.Chat" Style="font-size: 60px; color: white; margin-bottom: 15px;" />
                                <h3 style="color: white; font-weight: 800; font-size: 1.8rem; line-height: 1.2; margin-bottom: 10px; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">Santiago Conecta por WhatsApp</h3>
                                <p style="color: rgba(255,255,255,0.95); font-size: 1.05rem; line-height: 1.5; margin-bottom: 20px;">Resuelve tus dudas y reporta incidencias directo desde tu celular, las 24 horas.</p>
                                <button @onclick="OpenWhatsAppInfo" class="slider-action-btn" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.5); color: white; padding: 10px 20px; border-radius: 30px; font-weight: 700; width: fit-content; transition: all 0.3s ease;">Ir a WhatsApp</button>
                            </div>
                        </MudCarouselItem>

                        <!-- Slide 2: Noticias -->
                        <MudCarouselItem Transition="Transition.Slide">
                            <div style="height: 100%; display: flex; flex-direction: column; justify-content: center; padding: 40px; position: relative; z-index: 2;">
                                <span class="badge" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); color: white; padding: 8px 15px; border-radius: 20px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; display: inline-block; width: max-content; border: 1px solid rgba(255,255,255,0.3);">Noticias</span>
                                <MudIcon Icon="@Icons.Material.Filled.Article" Style="font-size: 60px; color: white; margin-bottom: 15px;" />
                                <h3 style="color: white; font-weight: 800; font-size: 1.8rem; line-height: 1.2; margin-bottom: 10px; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">Conoce la sección de Noticias</h3>
                                <p style="color: rgba(255,255,255,0.95); font-size: 1.05rem; line-height: 1.5; margin-bottom: 20px;">Mantente informado de los últimos comunicados, eventos y acontecimientos importantes en Santiago Papasquiaro.</p>
                                <button @onclick='() => NavManager.NavigateTo("/noticias", forceLoad: true)' class="slider-action-btn" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.5); color: white; padding: 10px 20px; border-radius: 30px; font-weight: 700; width: fit-content; transition: all 0.3s ease;">Ver Noticias</button>
                            </div>
                        </MudCarouselItem>

                        <!-- Slide 3: Emprendimientos -->
                        <MudCarouselItem Transition="Transition.Slide">
                            <div style="height: 100%; display: flex; flex-direction: column; justify-content: center; padding: 40px; position: relative; z-index: 2;">
                                <span class="badge" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); color: white; padding: 8px 15px; border-radius: 20px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; display: inline-block; width: max-content; border: 1px solid rgba(255,255,255,0.3);">Emprendimientos</span>
                                <MudIcon Icon="@Icons.Material.Filled.Storefront" Style="font-size: 60px; color: white; margin-bottom: 15px;" />
                                <h3 style="color: white; font-weight: 800; font-size: 1.8rem; line-height: 1.2; margin-bottom: 10px; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">Apoya el Comercio Local</h3>
                                <p style="color: rgba(255,255,255,0.95); font-size: 1.05rem; line-height: 1.5; margin-bottom: 20px;">Descubre y apoya a los negocios locales y emprendedores de nuestra comunidad en nuestro catálogo interactivo.</p>
                                <button @onclick='() => NavManager.NavigateTo("/emprendimientos", forceLoad: true)' class="slider-action-btn" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.5); color: white; padding: 10px 20px; border-radius: 30px; font-weight: 700; width: fit-content; transition: all 0.3s ease;">Ver Emprendimientos</button>
                            </div>
                        </MudCarouselItem>

                        <!-- Slide 4: Trámites -->
                        <MudCarouselItem Transition="Transition.Slide">
                            <div style="height: 100%; display: flex; flex-direction: column; justify-content: center; padding: 40px; position: relative; z-index: 2;">
                                <span class="badge" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); color: white; padding: 8px 15px; border-radius: 20px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; display: inline-block; width: max-content; border: 1px solid rgba(255,255,255,0.3);">Trámites</span>
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Style="font-size: 60px; color: white; margin-bottom: 15px;" />
                                <h3 style="color: white; font-weight: 800; font-size: 1.8rem; line-height: 1.2; margin-bottom: 10px; text-shadow: 0 2px 4px rgba(0,0,0,0.3);">Catálogo de Trámites</h3>
                                <p style="color: rgba(255,255,255,0.95); font-size: 1.05rem; line-height: 1.5; margin-bottom: 20px;">Consulta requisitos, costos y ubicaciones de los trámites municipales en un solo lugar y de forma transparente.</p>
                                <button @onclick='() => NavManager.NavigateTo("/tramites", forceLoad: true)' class="slider-action-btn" style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.5); color: white; padding: 10px 20px; border-radius: 30px; font-weight: 700; width: fit-content; transition: all 0.3s ease;">Ver Trámites</button>
                            </div>
                        </MudCarouselItem>
                    </MudCarousel>
                </div>
            </div>

            <!-- Eventos Destacados -->
            @if (destacados != null && destacados.Any())
            {
                <div class="col-lg-6 mb-4">
                    <MudCarousel Class="mud-width-full" Style="height: 100%; min-height: 420px; border-radius: 20px; box-shadow: 0 15px 35px rgba(0,0,0,0.1); color: white;" ShowArrows="@(destacados.Count > 1)" ShowBullets="@(destacados.Count > 1)" AutoCycle="true" EnableSwipeGesture="true" TData="object">
                        @foreach (var ev in destacados)
                        {
                            <MudCarouselItem Transition="Transition.Slide">
                                <div class="destacado-card evento-destacado" style="border-radius: 20px; overflow: hidden; height: 100%; display: flex; flex-direction: column; cursor: pointer; transition: transform 0.3s ease; position: relative;" @onclick='() => NavManager.NavigateTo($"/eventos/{ev.iIdEvento}", forceLoad: true)'>
                                    
                                    <!-- Imagen de Fondo Absoluto -->
                                    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1;">
                                        <img src="@(string.IsNullOrEmpty(ev.vchImagenPortada) ? "images/default-evento.jpg" : ev.vchImagenPortada)" alt="@ev.vchNombre" style="width: 100%; height: 100%; object-fit: cover; object-position: center 25%; transition: transform 0.5s ease;" />
                                    </div>
                                    
                                    <!-- Gradiente para Texto -->
                                    <div style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: linear-gradient(to bottom, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.4) 40%, rgba(0,0,0,0.9) 100%); z-index: 2;"></div>

                                    <!-- Etiqueta Fecha -->
                                    @if (ev.dtFechaInicio != null && ev.dtFechaInicio != DateTime.MinValue)
                                    {
                                        <div style="position: absolute; top: 20px; right: 20px; background: rgba(255,255,255,0.95); backdrop-filter: blur(5px); padding: 10px 15px; border-radius: 12px; text-align: center; box-shadow: 0 4px 15px rgba(0,0,0,0.15); z-index: 3;">
                                            <div style="color: #d81b60; font-weight: 900; font-size: 1.4rem; line-height: 1;">@ev.dtFechaInicio.Day</div>
                                            <div style="color: #4a148c; font-weight: 800; font-size: 0.8rem; text-transform: uppercase;">@ev.dtFechaInicio.ToString("MMM", new System.Globalization.CultureInfo("es-MX"))</div>
                                        </div>
                                    }

                                    <!-- Contenido Inferior -->
                                    <div class="evento-info" style="padding: 30px 30px 45px 30px; display: flex; flex-direction: column; position: relative; z-index: 3; margin-top: auto;">
                                        <span style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); color: white; padding: 6px 12px; border-radius: 20px; font-weight: 800; font-size: 0.75rem; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; display: inline-block; width: max-content; border: 1px solid rgba(255,255,255,0.3);">Evento Destacado</span>
                                        <h3 style="color: white; font-weight: 800; font-size: 1.4rem; line-height: 1.3; margin-bottom: 15px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; text-shadow: 0 2px 4px rgba(0,0,0,0.5);">@ev.vchNombre</h3>
                                        
                                        <div style="margin-bottom: 8px; display: flex; align-items: flex-start; color: rgba(255,255,255,0.95); font-size: 0.95rem;">
                                            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Style="color: #ffb4a2; font-size: 18px; margin-right: 8px; margin-top: 2px;" />
                                            <span style="display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; overflow: hidden; text-overflow: ellipsis; text-shadow: 0 1px 2px rgba(0,0,0,0.5);">@(string.IsNullOrEmpty(ev.vchLugar) ? "Por confirmar" : ev.vchLugar)</span>
                                        </div>
                                        <div style="margin-bottom: 20px; display: flex; align-items: center; color: rgba(255,255,255,0.95); font-size: 0.95rem;">
                                            <MudIcon Icon="@Icons.Material.Filled.ConfirmationNumber" Style="color: #ffb4a2; font-size: 18px; margin-right: 8px;" />
                                            <span style="text-shadow: 0 1px 2px rgba(0,0,0,0.5);">Costo: <strong style="color: white;">@(string.IsNullOrEmpty(ev.vchCostoTexto) ? "Entrada Libre" : ev.vchCostoTexto)</strong></span>
                                        </div>
                                        
                                        <div>
                                            <button style="background: rgba(255,255,255,0.2); backdrop-filter: blur(5px); border: 1px solid rgba(255,255,255,0.5); color: white; padding: 10px 25px; border-radius: 30px; width: 100%; transition: all 0.3s ease; display: flex; justify-content: center; align-items: center; gap: 8px; font-weight: 700;" class="slider-action-btn">
                                                Ver Detalles <MudIcon Icon="@Icons.Material.Filled.Event" Style="font-size: 18px;" />
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </MudCarouselItem>
                        }
                    </MudCarousel>
                </div>
            }
        </div>
    </div>
</section>

<!-- ***** Módulos Principales ***** -->
<section class="section home-feature" style="margin-top: 40px; position: relative; z-index: 10;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="row justify-content-center">
                    <!-- Trámites -->
                    <div class="col-lg-4 col-md-6 col-sm-6 col-12 mb-4" @onclick='() => NavManager.NavigateTo("/tramites", forceLoad: true)' style="cursor: pointer;">
                        <div class="features-small-item" style="border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s ease;">
                            <div class="icon" style="background: #fce4ec; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <h5 class="features-title" style="color: #880e4f; font-weight: 700;">Catálogo de Trámites</h5>
                            <p>Consulta requisitos, costos y ubicaciones de los trámites municipales en un solo lugar y de forma transparente.</p>
                        </div>
                    </div>
                    <!-- Noticias -->
                    <div class="col-lg-4 col-md-6 col-sm-6 col-12 mb-4" @onclick='() => NavManager.NavigateTo("/noticias", forceLoad: true)' style="cursor: pointer;">
                        <div class="features-small-item" style="border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s ease;">
                            <div class="icon" style="background: #fce4ec; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <h5 class="features-title" style="color: #880e4f; font-weight: 700;">Noticias y Avisos</h5>
                            <p>Mantente informado sobre los comunicados oficiales, eventos y noticias relevantes de Santiago Papasquiaro.</p>
                        </div>
                    </div>
                    <!-- Chatbot Info -->
                    <div class="col-lg-4 col-md-6 col-sm-6 col-12 mb-4" @onclick="OpenChatbot" style="cursor: pointer;">
                        <div class="features-small-item" style="border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s ease;">
                            <div class="icon" style="background: #fce4ec; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <h5 class="features-title" style="color: #880e4f; font-weight: 700;">Inteligencia Artificial</h5>
                            <p>Nuestro chatbot responde al instante a tus preguntas mediante lenguaje natural. ¡Pruébalo ahora mismo!</p>
                        </div>
                    </div>
                    <!-- Emprendimientos -->
                    <div class="col-lg-4 col-md-6 col-sm-6 col-12 mb-4" @onclick='() => NavManager.NavigateTo("/emprendimientos", forceLoad: true)' style="cursor: pointer;">
                        <div class="features-small-item" style="border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s ease;">
                            <div class="icon" style="background: #fce4ec; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                <MudIcon Icon="@Icons.Material.Filled.Storefront" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <h5 class="features-title" style="color: #880e4f; font-weight: 700;">Emprendimientos</h5>
                            <p>Descubre y apoya a los negocios locales y emprendedores de nuestra comunidad en nuestro catálogo interactivo.</p>
                        </div>
                    </div>
                    <!-- WhatsApp -->
                    <div class="col-lg-4 col-md-6 col-sm-6 col-12 mb-4" @onclick="OpenWhatsAppInfo" style="cursor: pointer;">
                        <div class="features-small-item" style="border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s ease;">
                            <div class="icon" style="background: #fce4ec; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                <MudIcon Icon="@Icons.Material.Filled.Chat" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <h5 class="features-title" style="color: #880e4f; font-weight: 700;">WhatsApp Bot</h5>
