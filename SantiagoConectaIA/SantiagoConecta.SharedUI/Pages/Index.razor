<PageTitle>Santiaguero Conecta - Inicio</PageTitle>

<!-- ***** Hero Section (Bienvenida) ***** -->
<div class="welcome-area hero-animated-bg" id="welcome" style="min-height: 85vh; display: flex; align-items: center; position: relative; overflow: hidden;">
    
    <!-- Efecto Glow que sigue al cursor -->
    <div class="hero-glow" id="hero-glow"></div>

    <!-- Sistema interactivo de partículas en Canvas -->
    <canvas id="hero-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; opacity: 0.8;"></canvas>

    <div class="header-text" style="width: 100%; position: relative; z-index: 5; padding-bottom: 8vh;">
        <div class="container">
            <div class="row">
                <div class="col-xl-8 col-lg-10 col-md-12 col-sm-12 mx-auto text-center" style="display: flex; flex-direction: column; align-items: center;">
                    
                    <!-- Última Noticia Glass Card -->
                    @if (latestNoticia != null)
                    {
                        <div class="news-card-glass" @onclick='() => NavManager.NavigateTo($"/noticias/{latestNoticia.iIdNoticia}")' style="width: 96%; max-width: 600px; padding: 16px 24px; margin-top: -60px; margin-bottom: 40px; border-radius: 28px; display: inline-flex; align-items: center; justify-content: space-between; gap: 16px; background: rgba(255, 255, 255, 0.1); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border: 1px solid rgba(255, 255, 255, 0.25); box-shadow: 0 8px 32px rgba(0, 0, 0, 0.15); cursor: pointer; transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1); animation: slideDownFade 0.8s ease-out;" onmouseover="this.style.background='rgba(255, 255, 255, 0.2)'; this.style.transform='translateY(-3px)'; this.style.boxShadow='0 12px 40px rgba(0,0,0,0.2)';" onmouseout="this.style.background='rgba(255, 255, 255, 0.1)'; this.style.transform='translateY(0)'; this.style.boxShadow='0 8px 32px rgba(0, 0, 0, 0.15)';">
                            <div class="badge-new" style="background: linear-gradient(135deg, #ffb4a2, #ff8a65); color: #880e4f; padding: 6px 14px; border-radius: 20px; font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.5px; box-shadow: 0 2px 8px rgba(255, 180, 162, 0.4); white-space: nowrap; flex-shrink: 0; align-self: flex-start; margin-top: 2px;">
                                @(latestNoticia.Categoria?.vchNombre ?? "Noticia")
                            </div>
                            <MudText Typo="Typo.body2" Style="color: white; font-weight: 500; font-size: 1.1rem; line-height: 1.4; margin: 0; text-shadow: 0 1px 2px rgba(0,0,0,0.2); white-space: normal; flex-grow: 1; text-align: left;">@latestNoticia.vchTitulo</MudText>
                            <MudIcon Icon="@Icons.Material.Filled.ArrowForwardIos" Style="color: rgba(255,255,255,0.7); font-size: 18px; margin-left: 6px; flex-shrink: 0;" />
                        </div>
                    }

                    <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="font-size: 60px; color: #ffb4a2; margin-bottom: 20px; animation: float 3s ease-in-out infinite;" />
                    <h1 style="color: white; font-weight: 800; font-size: 3.5rem; margin-bottom: 20px; text-shadow: 0 4px 20px rgba(0,0,0,0.3); letter-spacing: -1px;">
                        Bienvenido a <span style="color: #ffb4a2;">Santiaguero Conecta</span>
                    </h1>
                    <p style="color: rgba(255, 255, 255, 0.95); font-size: 1.25rem; margin-bottom: 40px; font-weight: 300; line-height: 1.6; text-shadow: 0 2px 10px rgba(0,0,0,0.2);">
                        Tu Asistente Virtual Inteligente 24/7. El H. Ayuntamiento de Santiago Papasquiaro pone a tu disposición esta herramienta de nueva generación para resolver tus dudas, consultar trámites y evitar filas.
                    </p>
                    <button class="main-button-slider hero-btn" @onclick="OpenChatbot">
                        <i class="fa fa-comments mr-2"></i> Conversar con la IA
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Ondas Animadas SVG -->
    <div class="waves-container">
        <svg class="waves" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
            <defs>
                <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s 58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
            </defs>
            <g class="parallax">
                <use xlink:href="#gentle-wave" x="48" y="0" fill="rgba(255,255,255,0.7" />
                <use xlink:href="#gentle-wave" x="48" y="3" fill="rgba(255,255,255,0.5)" />
                <use xlink:href="#gentle-wave" x="48" y="5" fill="rgba(255,255,255,0.3)" />
                <use xlink:href="#gentle-wave" x="48" y="7" fill="#ffffff" />
            </g>
        </svg>
    </div>
</div>
<!-- ***** Hero Section End ***** -->

<!-- ***** Módulos Principales ***** -->
