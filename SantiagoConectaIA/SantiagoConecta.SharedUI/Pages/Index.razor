@code {
    private ContactModel contactModel = new();
    private bool _isSubmitting = false;
    private string _successMessage = string.Empty;
    private string _errorMessage = string.Empty;
    private Noticia latestNoticia;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var response = await dataNoticias.PostGetAllNoticias(new PostGetNoticias { bActivo = true });
            if (response != null && response.IsSuccess && response.Data != null)
            {
                latestNoticia = response.Data.OrderByDescending(x => x.dtFechaPublicacion).FirstOrDefault();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error cargando última noticia: {ex.Message}");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var initScript = @"
                const hero = document.getElementById('welcome');
                const glow = document.getElementById('hero-glow');
                const canvas = document.getElementById('hero-canvas');
                
                if (hero && glow && canvas) {
                    const ctx = canvas.getContext('2d');
                    let width, height;
                    let particles = [];
                    let mouse = { x: -1000, y: -1000 };

                    function resize() {
                        width = hero.clientWidth;
                        height = hero.clientHeight;
                        canvas.width = width;
                        canvas.height = height;
                    }
                    window.addEventListener('resize', resize);
                    resize();

                    // Partículas
                    class Particle {
                        constructor() {
                            this.x = Math.random() * width;
                            this.y = Math.random() * height;
                            this.vx = (Math.random() - 0.5) * 1;
                            this.vy = (Math.random() - 0.5) * 1;
                            this.radius = Math.random() * 2 + 1;
                        }
                        update() {
                            // Interacción con linterna (mouse)
                            let dx = mouse.x - this.x;
                            let dy = mouse.y - this.y;
                            let distance = Math.sqrt(dx * dx + dy * dy);
                            
                            // Efecto repulsión suave
                            if (distance < 150) {
                                let force = (150 - distance) / 150;
                                this.vx -= (dx / distance) * force * 0.5;
                                this.vy -= (dy / distance) * force * 0.5;
                            }

                            // Fricción y límite de velocidad
                            this.vx *= 0.98;
                            this.vy *= 0.98;
                            
                            // Movimiento natural base
                            this.vx += (Math.random() - 0.5) * 0.1;
                            this.vy += (Math.random() - 0.5) * 0.1;

                            this.x += this.vx;
                            this.y += this.vy;

                            // Rebote en bordes
                            if (this.x < 0 || this.x > width) this.vx *= -1;
                            if (this.y < 0 || this.y > height) this.vy *= -1;
                        }
                        draw() {
                            ctx.beginPath();
                            ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                            ctx.fillStyle = 'rgba(255, 255, 255, 0.6)';
                            ctx.fill();
                        }
                    }

                    for (let i = 0; i < 60; i++) particles.push(new Particle());

                    function animate() {
                        ctx.clearRect(0, 0, width, height);
                        
                        // Conexiones
                        for(let i=0; i<particles.length; i++){
                            particles[i].update();
                            particles[i].draw();
                            for(let j=i; j<particles.length; j++){
                                let dx = particles[i].x - particles[j].x;
                                let dy = particles[i].y - particles[j].y;
                                let dist = Math.sqrt(dx*dx + dy*dy);
                                if(dist < 100){
                                    ctx.beginPath();
                                    ctx.strokeStyle = `rgba(255,255,255,${0.2 - dist/500})`;
                                    ctx.lineWidth = 1;
                                    ctx.moveTo(particles[i].x, particles[i].y);
                                    ctx.lineTo(particles[j].x, particles[j].y);
                                    ctx.stroke();
                                }
                            }
                        }
                        requestAnimationFrame(animate);
                    }
                    animate();

                    hero.addEventListener('mousemove', (e) => {
                        const rect = hero.getBoundingClientRect();
                        mouse.x = e.clientX - rect.left;
                        mouse.y = e.clientY - rect.top;
                        
                        // Glow Linterna
                        glow.style.left = mouse.x + 'px';
                        glow.style.top = mouse.y + 'px';
                        glow.style.opacity = '1';
                        // Hacer la linterna más fuerte
                        glow.style.background = 'radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, rgba(255, 180, 162, 0.15) 30%, transparent 70%)';
                    });
                    hero.addEventListener('mouseleave', () => {
                        glow.style.opacity = '0';
                        mouse.x = -1000;
                        mouse.y = -1000;
                    });
                }
            ";
            try {
                await JS.InvokeVoidAsync("eval", initScript);
            } catch { }
        }
    }

    private async Task HandleSubmit()
    {
        _isSubmitting = true;
        _successMessage = string.Empty;
        _errorMessage = string.Empty;
        StateHasChanged();

        try
        {
            var postModel = new PostSaveBuzonCiudadano
            {
                nvchNombreCiudadano = contactModel.Name,
                nvchEmail = contactModel.Email,
                nvchTelefono = contactModel.Phone,
                nvchCategoria = contactModel.Category,
                nvchDescripcion = contactModel.Message
            };

            var result = await _dataBuzon.PostSaveReporte(postModel);

            if (result != null && result.IsSuccess)
            {
                _successMessage = "Tu mensaje ha sido enviado exitosamente. ¡Gracias por tus comentarios!";
                contactModel = new();
            }
            else
            {
                _errorMessage = result?.Message ?? "Ocurrió un error al enviar tu mensaje. Intenta de nuevo.";
            }
        }
        catch (Exception ex)
        {
            _errorMessage = "Error de conexión. Por favor, intenta más tarde.";
        }
        finally
        {
            _isSubmitting = false;
            StateHasChanged();
        }
    }

    private async Task OpenChatbot()
    {
        try {
            await JS.InvokeVoidAsync("eval", "document.querySelector('.chatbot-container .pulse-animation')?.click()");
        } catch { }
    }

