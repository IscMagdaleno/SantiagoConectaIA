@page "/eventos"
@using SantiagoConectaIA.Share.Objects.EventosModulo
@using SantiagoConectaIA.Share.PostClass.EventosModulo
<PageTitle>Santiago Conecta - Agenda de Eventos</PageTitle>

    <!-- Hero Section -->
    <div class="custom-hero-header">
        <div class="container relative z-10 mx-auto px-4 text-center">
            <MudIcon Icon="@Icons.Material.Filled.Event" Style="font-size: 56px; color: #ffffff; animation: float 3s ease-in-out infinite; filter: drop-shadow(0 4px 10px rgba(0,0,0,0.15));" />
            <h1 class="header-title mt-2">Eventos</h1>
            <p class="header-subtitle">Descubre las ferias, conciertos, exposiciones y más actividades en Santiago Papasquiaro</p>
        </div>
        <!-- Animated waves at bottom -->
        <div class="waves-wrapper">
            <svg class="waves" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink"
                 viewBox="0 24 150 28" preserveAspectRatio="none" shape-rendering="auto">
                <defs>
                    <path id="gentle-wave" d="M-160 44c30 0 58-18 88-18s58 18 88 18 58-18 88-18 58 18 88 18 v44h-352z" />
                </defs>
                <g class="parallax">
                    <use xlink:href="#gentle-wave" x="48" y="0" fill="rgba(255, 255, 255, 0.7)" />
                    <use xlink:href="#gentle-wave" x="48" y="3" fill="rgba(255, 255, 255, 0.5)" />
                    <use xlink:href="#gentle-wave" x="48" y="5" fill="rgba(255, 255, 255, 0.3)" />
                    <use xlink:href="#gentle-wave" x="48" y="7" fill="#f8f9fa" />
                </g>
            </svg>
        </div>
    </div>

    <div class="eventos-container py-8 px-4" style="background-color: #f8f9fa; min-height: calc(100vh - 350px);">
        <div class="container" style="max-width: 1200px; margin: 0 auto; padding-top: 2rem;">
            <!-- Filtros -->
            <div class="row mb-5 justify-content-center">
                <div class="col-12 col-md-10">
                    <div class="filter-card p-4 shadow-sm" style="background: white; border-radius: 15px;">
                        <MudTextField @bind-Value="SearchQuery" 
                                      Placeholder="Buscar eventos..." 
                                      Adornment="Adornment.Start" 
                                      AdornmentIcon="@Icons.Material.Filled.Search" 
                                      IconSize="Size.Medium"
                                      Variant="Variant.Outlined" 
                                      Immediate="true" />

                        <div class="d-flex flex-wrap gap-2 mt-4 justify-content-center">
                            <button class="btn @(selectedCategoryId == null ? "btn-primary" : "btn-outline-primary") rounded-pill px-4" style="@(selectedCategoryId == null ? "background-color: #e91e63; border-color: #e91e63; color: white;" : "color: #e91e63; border-color: #e91e63;")" @onclick="() => FilterByCategory(null)">Todos</button>
                            @foreach (var cat in categorias)
                            {
                                <button class="btn @(selectedCategoryId == cat.iIdCategoriaEvento ? "btn-primary" : "btn-outline-primary") rounded-pill px-4" style="@(selectedCategoryId == cat.iIdCategoriaEvento ? "background-color: #e91e63; border-color: #e91e63; color: white;" : "color: #e91e63; border-color: #e91e63;")" @onclick="() => FilterByCategory(cat.iIdCategoriaEvento)">@cat.vchNombre</button>
                            }
                        </div>
                    </div>
                </div>
            </div>

            <!-- Listado -->
            @if (!filteredEventos.Any())
            {
                <div class="text-center py-5">
                    <MudIcon Icon="@Icons.Material.Filled.EventBusy" Style="font-size: 64px; color: #bdbdbd;" />
                    <h3 class="mt-4" style="color: #616161;">No se encontraron eventos</h3>
                </div>
            }
            else
            {
                <div class="row" style="display: flex; flex-wrap: wrap; margin-right: -15px; margin-left: -15px;">
                    @foreach (var evento in filteredEventos)
                    {
                        <div class="col-12 col-md-6 col-lg-4 mb-4" style="padding-right: 15px; padding-left: 15px;">
                            <div class="card h-100 shadow-sm border-0 event-card" style="border-radius: 15px; overflow: hidden; cursor: pointer; transition: transform 0.3s ease; display: flex; flex-direction: column;" @onclick="() => VerDetalle(evento)">
                                <div style="position: relative; height: 200px; overflow: hidden;">
                                    <img src="@(string.IsNullOrEmpty(evento.vchImagenPortada) ? "https://placehold.co/600x400/e9ecef/495057?text=Sin+Imagen" : evento.vchImagenPortada)" alt="@evento.vchNombre" style="width: 100%; height: 100%; object-fit: cover;" />
                                    @if (evento.bDestacado)
                                    {
                                        <span class="badge bg-danger position-absolute" style="top: 15px; right: 15px; padding: 8px 12px; border-radius: 20px;">★ Destacado</span>
                                    }
                                </div>
                                <div class="card-body p-4" style="flex: 1; display: flex; flex-direction: column;">
                                    <div class="d-flex align-items-center mb-2" style="color: #e91e63; display: flex; align-items: center;">
                                        <MudIcon Icon="@Icons.Material.Filled.CalendarMonth" Size="Size.Small" Class="me-1" />
                                        <span style="font-weight: 600; font-size: 0.9rem; margin-left: 5px;">@evento.dtFechaInicio.ToString("dd MMM yyyy, HH:mm")</span>
                                    </div>
                                    <h4 class="card-title font-weight-bold mb-3" style="font-size: 1.25rem;">@evento.vchNombre</h4>
                                    <div class="d-flex align-items-center mb-2 text-muted" style="display: flex; align-items: center;">
                                        <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="me-2" />
                                        <span style="margin-left: 5px;">@(string.IsNullOrEmpty(evento.vchLugar) ? "Ubicación por confirmar" : evento.vchLugar)</span>
                                    </div>
                                    <div style="flex-grow: 1;"></div>
                                    <div class="d-flex justify-content-between align-items-center mt-4" style="display: flex; justify-content: space-between; align-items: center;">
                                        <span class="badge" style="background-color: #fce4ec; color: #c2185b; padding: 5px 10px; border-radius: 10px;">@GetCategoryName(evento.iIdCategoriaEvento)</span>
                                        <span style="font-weight: 700; color: #2e7d32;">@(string.IsNullOrEmpty(evento.vchCostoTexto) ? "Entrada Libre" : evento.vchCostoTexto)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
<style>
    .event-card:hover {
        transform: translateY(-5px) !important;
        box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
    }
    @@keyframes float {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-10px); }
        100% { transform: translateY(0px); }
    }
    @@media (min-width: 992px) {
        .col-lg-8 { flex: 0 0 66.666667% !important; max-width: 66.666667% !important; }
        .col-lg-4 { flex: 0 0 33.333333% !important; max-width: 33.333333% !important; }
    }
</style>
