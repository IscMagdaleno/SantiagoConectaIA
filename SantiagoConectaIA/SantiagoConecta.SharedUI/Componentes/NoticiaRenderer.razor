@using SantiagoConectaIA.Share.Objects.NoticiasModule
@using MudBlazor

@if (this.Noticia == null)
{
    <div class="d-flex justify-center align-center py-8">
        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
    </div>
}
else if (this.Noticia.Filas == null || !this.Noticia.Filas.Any() || !this.Noticia.Filas.Any(f => f.Metadatos != null && f.Metadatos.Any()))
{
    <!-- Vista por defecto si no hay metadatos aún -->
    <div class="default-content-view animate-fade-in pa-4">
        <p class="noticia-body-text">@this.Noticia.nvchContenido</p>
    </div>
}
else
{
    <div class="dynamic-noticia-renderer">
        <div class="editorial-news-flow">
            @foreach (var fila in this.Noticia.Filas.OrderBy(f => f.iOrden))
            {
                if (fila.Metadatos == null || !fila.Metadatos.Any()) continue;

                <div class="public-row-grid">
                    @foreach (var bloque in fila.Metadatos.OrderBy(m => m.iOrden))
                    {
                        var width = GetBlockWidth(bloque);
                        var floatStyle = GetBlockFloat(bloque);
                        var heightStyle = GetBlockHeight(bloque);
                        
                        var gridSpan = width switch
                        {
                            3 => 3,
                            6 => 6,
                            9 => 9,
                            12 => 12,
                            _ => 12
                        };

                        var alignStyle = floatStyle switch
                        {
                            "center" => "text-align: center; margin: 0 auto;",
                            "right" => "text-align: right; margin-left: auto;",
                            _ => "text-align: left;"
                        };

                // Altura configurable para elementos visuales que no sean texto
                var contentStyle = "";
                if (heightStyle != "auto" && bloque.iIdTipoDato != TipoDatoMetadato.Contenido)
                {
                    contentStyle = $"height: {heightStyle}; object-fit: cover; width: 100%;";
                }

                <div style="grid-column: span @gridSpan; @alignStyle" class="news-block-item animate-fade-in">
                    @* Título del Bloque (vchTitulo) *@
                    @if (!string.IsNullOrWhiteSpace(bloque.vchTitulo) && bloque.vchTitulo != "Bloque sin Título" && bloque.vchTitulo != "bloque" && bloque.vchTitulo != "contenido.principal" && bloque.vchTitulo != "Contenido")
                    {
                        <h4 class="news-block-title">@bloque.vchTitulo</h4>
                    }

                    @switch (bloque.iIdTipoDato)
                    {
                        case TipoDatoMetadato.Video:
                            <div class="block-video-container w-100" style="@contentStyle">
                                @if (!string.IsNullOrWhiteSpace(bloque.nvchValor) && (bloque.nvchValor.Contains("youtube.com") || bloque.nvchValor.Contains("youtu.be")))
                                {
                                    var videoId = GetYouTubeVideoId(bloque.nvchValor);
                                    var thumbnailUrl = !string.IsNullOrEmpty(videoId) 
                                        ? $"https://img.youtube.com/vi/{videoId}/hqdefault.jpg" 
                                        : "";
                                    
                                    <a href="@bloque.nvchValor" target="_blank" rel="noopener noreferrer" class="youtube-thumbnail-link">
                                        <div class="youtube-card rounded-xl shadow-lg overflow-hidden position-relative" style="@(heightStyle != "auto" ? $"height: {heightStyle};" : "")">
                                            <img src="@thumbnailUrl" alt="Video de la Noticia" class="youtube-bg-img" style="@(heightStyle != "auto" ? "height: 100%;" : "")" />
                                            <div class="youtube-overlay">
                                                <div class="play-button-container">
                                                    <div class="play-button-inner">
                                                        <svg viewBox="0 0 24 24" class="play-svg">
                                                            <path d="M8 5v14l11-7z" fill="#ffffff" />
                                                        </svg>
                                                    </div>
                                                </div>
                                                <div class="youtube-text-tag">
                                                    <span>Ver Video en YouTube</span>
                                                </div>
                                            </div>
                                        </div>
                                    </a>
                                }
                                else if (!string.IsNullOrWhiteSpace(bloque.nvchValor))
                                {
                                    <div class="video-responsive rounded-xl shadow-lg overflow-hidden" style="@(heightStyle != "auto" ? $"height: {heightStyle};" : "")">
                                        <video controls width="100%" class="rounded-xl" style="@(heightStyle != "auto" ? "height: 100%; object-fit: cover;" : "")">
                                            <source src="@bloque.nvchValor" type="video/mp4" />
                                            Tu navegador no soporta reproducción de video.
                                        </video>
                                    </div>
                                }
                            </div>
                            break;

                        case TipoDatoMetadato.GaleriaImagenes:
                            {
                                var urls = bloque.nvchValor?.Split(';', System.StringSplitOptions.RemoveEmptyEntries) ?? System.Array.Empty<string>();
                                if (urls.Any())
                                {
                                    <div class="block-gallery-container pa-4 border rounded-xl bg-light w-100" style="box-shadow: inset 0 2px 4px rgba(0,0,0,0.02); @(heightStyle != "auto" ? $"height: {heightStyle}; overflow-y: auto;" : "")">
                                        <div class="gallery-grid">
                                            @foreach (var url in urls)
                                            {
                                                <div class="premium-gallery-item">
                                                    <img src="@url" class="gallery-img" />
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            }
                            break;

                        case TipoDatoMetadato.Contenido:
                            <div class="block-content-container w-100 noticia-html-content">
                                @((MarkupString)bloque.nvchValor)
                            </div>
                            break;

                        case TipoDatoMetadato.ImagenSola:
                            <div class="block-single-image w-100 text-center">
                                <img src="@bloque.nvchValor" class="rounded-xl shadow-lg" style="width: 100%; object-fit: cover; max-height: 800px; @(heightStyle != "auto" ? $"height: {heightStyle};" : "")" alt="Imagen de Noticia" />
                            </div>
                            break;

                        case TipoDatoMetadato.RedesSociales:
                            {
                                var redes = new System.Collections.Generic.Dictionary<string, string>();
                                try {
                                    if (!string.IsNullOrEmpty(bloque.nvchConfiguracion)) {
                                        redes = System.Text.Json.JsonSerializer.Deserialize<System.Collections.Generic.Dictionary<string, string>>(bloque.nvchConfiguracion);
                                    }
                                } catch { }

                                <div class="block-social d-flex flex-wrap gap-4 align-center justify-center my-4">
                                    @if (redes != null) {
                                        if (!string.IsNullOrWhiteSpace(redes.GetValueOrDefault("WhatsApp"))) {
                                            <MudIconButton Href="@(redes["WhatsApp"].StartsWith("http") ? redes["WhatsApp"] : $"https://wa.me/{redes["WhatsApp"]}")" Target="_blank" Icon="@Icons.Custom.Brands.WhatsApp" Color="Color.Success" Size="Size.Large" Variant="Variant.Outlined" Class="rounded-circle social-btn whatsapp-btn" />
                                        }
                                        if (!string.IsNullOrWhiteSpace(redes.GetValueOrDefault("Facebook"))) {
                                            <MudIconButton Href="@redes["Facebook"]" Target="_blank" Icon="@Icons.Custom.Brands.Facebook" Color="Color.Info" Size="Size.Large" Variant="Variant.Outlined" Class="rounded-circle social-btn facebook-btn" />
                                        }
                                        if (!string.IsNullOrWhiteSpace(redes.GetValueOrDefault("Instagram"))) {
                                            <MudIconButton Href="@redes["Instagram"]" Target="_blank" Icon="@Icons.Custom.Brands.Instagram" Color="Color.Secondary" Size="Size.Large" Variant="Variant.Outlined" Class="rounded-circle social-btn instagram-btn" />
                                        }
                                        if (!string.IsNullOrWhiteSpace(redes.GetValueOrDefault("TikTok"))) {
                                            <MudIconButton Href="@redes["TikTok"]" Target="_blank" Icon="@Icons.Custom.Brands.TikTok" Color="Color.Dark" Size="Size.Large" Variant="Variant.Outlined" Class="rounded-circle social-btn tiktok-btn" />
                                        }
                                        if (!string.IsNullOrWhiteSpace(redes.GetValueOrDefault("X"))) {
                                            <MudIconButton Href="@redes["X"]" Target="_blank" Icon="@Icons.Custom.Brands.Twitter" Color="Color.Dark" Size="Size.Large" Variant="Variant.Outlined" Class="rounded-circle social-btn x-btn" />
                                        }
                                    }
                                </div>
                            }
                            break;

                        case TipoDatoMetadato.DatosCuriosos:
                            <div class="block-curious-fact">
                                <div class="thought-bubble">
                                    <MudIcon Icon="@Icons.Material.Filled.Lightbulb" Color="Color.Warning" Size="Size.Large" Class="mb-2 bubble-icon" />
                                    <p class="noticia-body-text font-italic text-center m-0">@bloque.nvchValor</p>
                                </div>
                            </div>
                            break;
                    }
                </div>
                    }
                </div>
            }
        </div>
    </div>
}

<style>
    /* Flujo editorial responsivo estilo prensa */
    .editorial-news-flow {
        display: block;
        width: 100%;
        box-sizing: border-box;
    }

    .public-row-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 24px;
        margin-bottom: 32px;
        width: 100%;
        align-items: start;
    }

    .news-block-item {
        box-sizing: border-box;
        transition: transform 0.3s ease;
        width: 100%;
    }

    .news-block-title {
        font-family: 'Inter', sans-serif;
        font-size: 1.1rem;
        font-weight: 700;
        color: #1e293b;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-top: 12px;
        margin-bottom: 8px;
        border-bottom: 2px solid #e2e8f0;
        padding-bottom: 4px;
        display: block;
    }

    .noticia-body-text {
        font-size: 1.15rem;
        line-height: 1.8;
        color: #374151;
        font-weight: 400;
        text-align: justify;
        white-space: pre-line;
        margin: 0;
    }

    /* Estilos para el HTML inyectado de la noticia */
    .noticia-html-content {
        font-size: 1.15rem;
        line-height: 1.8;
        color: #374151;
        font-weight: 400;
        text-align: justify;
    }
    
    .noticia-html-content p {
        margin-bottom: 1.25rem;
    }
    
    .noticia-html-content h1, 
    .noticia-html-content h2, 
    .noticia-html-content h3, 
    .noticia-html-content h4, 
    .noticia-html-content h5 {
        color: #1e293b;
        margin-top: 1.5rem;
        margin-bottom: 1rem;
        font-weight: 700;
        line-height: 1.3;
    }
    
    .noticia-html-content a {
        color: #3b82f6;
        text-decoration: none;
    }
    
    .noticia-html-content a:hover {
        text-decoration: underline;
    }

    .noticia-html-content img {
        max-width: 100%;
        height: auto;
        border-radius: 12px;
        margin: 1.5rem 0;
    }
    
    .noticia-html-content ul, .noticia-html-content ol {
        margin-bottom: 1.25rem;
        padding-left: 2rem;
    }
    
    .noticia-html-content li {
        margin-bottom: 0.5rem;
    }

    .video-responsive {
        position: relative;
        overflow: hidden;
        width: 100%;
    }

    .animate-fade-in {
        animation: fadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(15px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* Estilos Premium para la tarjeta de YouTube */
    .youtube-thumbnail-link {
        text-decoration: none !important;
        display: block;
        border-radius: 16px;
        overflow: hidden;
    }

    .youtube-card {
        position: relative;
        width: 100%;
        height: 320px;
        background-color: #000000;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        border-radius: 16px;
    }

    .youtube-bg-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        opacity: 0.85;
        transition: transform 0.5s ease, filter 0.3s ease;
    }

    .youtube-thumbnail-link:hover .youtube-bg-img {
        transform: scale(1.05);
        filter: brightness(0.75);
    }

    .youtube-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        background: rgba(0, 0, 0, 0.2);
        transition: background-color 0.3s ease;
    }

    .youtube-thumbnail-link:hover .youtube-overlay {
        background: rgba(0, 0, 0, 0.35);
    }

    .play-button-container {
        width: 70px;
        height: 70px;
        border-radius: 50%;
        background-color: #ff0000;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 20px rgba(255, 0, 0, 0.4);
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275), background-color 0.3s ease;
    }

    .youtube-thumbnail-link:hover .play-button-container {
        transform: scale(1.15);
        background-color: #e60000;
        box-shadow: 0 6px 30px rgba(230, 0, 0, 0.6);
    }

    .play-button-inner {
        width: 28px;
        height: 28px;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .play-svg {
        width: 100%;
        height: 100%;
    }

    .youtube-text-tag {
        margin-top: 14px;
        background-color: rgba(0, 0, 0, 0.7);
        backdrop-filter: blur(8px);
        padding: 6px 14px;
        border-radius: 30px;
        border: 1px solid rgba(255, 255, 255, 0.15);
        transition: transform 0.3s ease, background-color 0.3s ease;
    }

    .youtube-text-tag span {
        color: #ffffff;
        font-weight: 600;
        font-size: 0.9rem;
        letter-spacing: 0.5px;
        font-family: 'Inter', sans-serif;
    }

    .youtube-thumbnail-link:hover .youtube-text-tag {
        background-color: rgba(255, 0, 0, 0.85);
        transform: translateY(-2px);
    }

    /* Galería Premium (Imágenes más grandes) */
    .gallery-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 16px;
        width: 100%;
    }
    .premium-gallery-item {
        position: relative;
        width: 100%;
        aspect-ratio: 4/3;
        overflow: hidden;
        border-radius: 16px;
        box-shadow: 0 4px 15px rgba(0,0,0,0.06);
        transition: all 0.3s ease;
    }
    .premium-gallery-item:hover {
        transform: translateY(-4px);
        box-shadow: 0 10px 25px rgba(0,0,0,0.1);
    }
    .gallery-img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }
    .premium-gallery-item:hover .gallery-img {
        transform: scale(1.05);
    }

    /* Botones Redes Sociales */
    .social-btn { transition: all 0.3s ease; }
    .social-btn:hover { transform: scale(1.1) translateY(-4px); box-shadow: 0 8px 15px rgba(0,0,0,0.1); }
    .whatsapp-btn:hover { color: #fff !important; background-color: #25D366 !important; border-color: #25D366 !important; }
    .facebook-btn:hover { color: #fff !important; background-color: #1877F2 !important; border-color: #1877F2 !important; }
    .instagram-btn:hover { color: #fff !important; background: linear-gradient(45deg, #f09433, #e6683c, #dc2743, #cc2366, #bc1888) !important; border-color: transparent !important; }
    .tiktok-btn:hover { color: #fff !important; background-color: #000000 !important; border-color: #000000 !important; }
    .x-btn:hover { color: #fff !important; background-color: #000000 !important; border-color: #000000 !important; }

    /* Datos Curiosos (Globo) */
    .thought-bubble {
        position: relative;
        background: #fdf8e4;
        border-radius: 30px;
        padding: 30px;
        border: 2px solid #fce79a;
        box-shadow: 0 10px 20px rgba(0,0,0,0.05);
        margin: 20px auto 40px auto;
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 800px;
    }
    .thought-bubble::before {
        content: '';
        position: absolute;
        background: #fdf8e4;
        border-radius: 50%;
        border: 2px solid #fce79a;
        width: 40px;
        height: 40px;
        bottom: -20px;
        left: 50px;
        z-index: 1;
    }
    .thought-bubble::after {
        content: '';
        position: absolute;
        background: #fdf8e4;
        border-radius: 50%;
        border: 2px solid #fce79a;
        width: 20px;
        height: 20px;
        bottom: -45px;
        left: 30px;
        z-index: 1;
    }

    /* Media queries para responsividad estrecha */
    @@media (max-width: 768px) {
        .public-row-grid {
            display: flex !important;
            flex-direction: column !important;
            gap: 16px !important;
            margin-bottom: 24px !important;
        }
        .news-block-item {
            grid-column: span 12 !important;
            width: 100% !important;
            margin: 0 0 16px 0 !important;
        }
        .youtube-card {
            height: 220px;
        }
    }
</style>

@code {
    [Parameter] public Noticia Noticia { get; set; }

    private int GetBlockWidth(NoticiaMetadato metadato)
    {
        if (metadato == null) return 12;
        return metadato.iAncho ?? 12;
    }

    private string GetBlockFloat(NoticiaMetadato metadato)
    {
        if (metadato == null) return "none";
        return !string.IsNullOrEmpty(metadato.vchAlineacion) ? metadato.vchAlineacion : "none";
    }

    private string GetBlockHeight(NoticiaMetadato metadato)
    {
        if (metadato == null) return "auto";
        return !string.IsNullOrEmpty(metadato.vchAlto) ? metadato.vchAlto : "auto";
    }

    private string GetYouTubeVideoId(string rawUrl)
    {
        try
        {
            if (rawUrl.Contains("embed/"))
            {
                return rawUrl.Split("embed/")[1].Split('?')[0];
            }

            if (rawUrl.Contains("youtu.be/"))
            {
                return rawUrl.Split("youtu.be/")[1].Split('?')[0];
            }

            if (rawUrl.Contains("v="))
            {
                return rawUrl.Split("v=")[1].Split('&')[0];
            }
        }
        catch { }
        return string.Empty;
    }
}
