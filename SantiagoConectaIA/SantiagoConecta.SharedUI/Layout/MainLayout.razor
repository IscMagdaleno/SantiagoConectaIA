@implements IDisposable
@inherits LayoutComponentBase
@using Microsoft.Extensions.Localization
@using SantiagoConecta.SharedUI.Shared
@using SantiagoConecta.SharedUI.Data
@using SantiagoConectaIA.Share.PostModels.AnalyticsModule
@inject IStringLocalizer<App> Localizer
@inject NavigationManager NavManager
@inject Data_Analytics AnalyticsService
@inject IJSRuntime JS

<MudThemeProvider Theme="@MyCustomTheme" />
<MudDialogProvider />
<MudSnackbarProvider />
<MudPopoverProvider />

<header class="header-area header-sticky">
    <div class="container">
        <div class="row">
            <div class="col-12">
                <nav class="main-nav">
                    <a href="/" class="logo d-flex align-center">
                        <img src="_content/SantiagoConecta.SharedUI/assets/images/LogoBuenoPNG.svg" style="height: 32px;" class="mr-2" alt="Logo" />
                        <span style="font-family: 'Montaser Arabic', sans-serif; font-weight: 700; font-size: clamp(16px, 4.5vw, 24px);">
                            <span style="color: #9b45c9;">Santiago</span> <span style="color: #cd4472;">Conecta</span>
                        </span>
                    </a>
                    <ul class="nav" style="@(IsMenuOpen ? "display: block !important;" : "")">
                        <li><NavLink href="/" Match="NavLinkMatch.All" @onclick="CloseMenu">Inicio</NavLink></li>
                        <li><NavLink href="tramites" @onclick="CloseMenu">Trámites</NavLink></li>
                        <li><NavLink href="noticias" @onclick="CloseMenu">Noticias</NavLink></li>
                        <li><NavLink href="eventos" @onclick="CloseMenu">Eventos</NavLink></li>
                        <li><a href="#contacto" @onclick="CloseMenu">Buzón Ciudadano</a></li>
                        <li><NavLink href="emprendimientos" @onclick="CloseMenu">Emprendimientos</NavLink></li>
                        <li><LanguageSwitcher /></li>
                    </ul>
                    <a class="menu-trigger @(IsMenuOpen ? "active" : "")" @onclick="ToggleMenu" @onclick:preventDefault>
                        <span>Menu</span>
                    </a>
                </nav>
            </div>
        </div>
    </div>
</header>
<main class="@(IsHomePage() ? "home-main" : "inner-main")">
    @Body
</main>

<ChatbotWidget />

<footer>
    <div class="container">
        <div class="row">
            <div class="col-lg-12 col-md-12 col-sm-12">
                <ul class="social">
                    <li><a href="https://www.facebook.com/share/1BQWjoGRyZ/"><i class="fa fa-facebook"></i></a></li>
                    <li><a href="https://www.instagram.com/santiago_conecta_?igsh=NWdzang1bHJjNnhq"><i class="fa fa-instagram"></i></a></li>
                </ul>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-12">
                <p class="copyright">Copyright &copy; Santiago Conecta 2026</p>
            </div>
        </div>
    </div>
</footer>

@code {
    private MudTheme MyCustomTheme = new MudTheme()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#d81b60", // Rosa Oscuro
            Secondary = "#880e4f", // Vino
            AppbarBackground = "#880e4f",
            AppbarText = "#ffffff"
        }
    };

    private bool IsMenuOpen = false;

    private void ToggleMenu()
    {
        IsMenuOpen = !IsMenuOpen;
    }

    private void CloseMenu()
    {
        IsMenuOpen = false;
    }

    protected override void OnInitialized()
    {
        NavManager.LocationChanged += OnLocationChanged;
    }

    private async void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        IsMenuOpen = false;
        StateHasChanged();

        try
        {
            var relativePath = NavManager.ToBaseRelativePath(NavManager.Uri);
            var pageName = string.IsNullOrEmpty(relativePath) ? "Index" : relativePath.Split('/')[0];

            var userAgent = await JS.InvokeAsync<string>("eval", "navigator.userAgent");
            var referrer = await JS.InvokeAsync<string>("eval", "document.referrer");

            var model = new PostSavePageVisit
            {
                vchPageUrl = NavManager.Uri,
                vchPageName = pageName,
                vchUserAgent = userAgent ?? string.Empty,
                vchReferrer = referrer ?? string.Empty,
                vchBrowser = ParseBrowser(userAgent),
                vchOperatingSystem = ParseOS(userAgent),
                vchDeviceType = ParseDevice(userAgent)
            };

            await AnalyticsService.PostSavePageVisit(model);
        }
        catch (Exception)
        {
            // Silently fail - analytics should not break the app
        }
    }

    private string ParseBrowser(string? userAgent)
    {
        if (string.IsNullOrEmpty(userAgent)) return "Unknown";
        if (userAgent.Contains("Edg/")) return "Edge";
        if (userAgent.Contains("Chrome/")) return "Chrome";
        if (userAgent.Contains("Firefox/")) return "Firefox";
        if (userAgent.Contains("Safari/")) return "Safari";
        return "Other";
    }

    private string ParseOS(string? userAgent)
    {
        if (string.IsNullOrEmpty(userAgent)) return "Unknown";
        if (userAgent.Contains("Windows")) return "Windows";
        if (userAgent.Contains("Mac OS")) return "macOS";
        if (userAgent.Contains("Linux")) return "Linux";
        if (userAgent.Contains("Android")) return "Android";
        if (userAgent.Contains("iPhone") || userAgent.Contains("iPad")) return "iOS";
        return "Other";
    }

    private string ParseDevice(string? userAgent)
    {
        if (string.IsNullOrEmpty(userAgent)) return "Unknown";
        if (userAgent.Contains("Mobile") || userAgent.Contains("Android")) return "Mobile";
        if (userAgent.Contains("iPad") || userAgent.Contains("Tablet")) return "Tablet";
        return "Desktop";
    }

    public void Dispose()
    {
        NavManager.LocationChanged -= OnLocationChanged;
    }

    private bool IsHomePage()
    {
        var relative = NavManager.ToBaseRelativePath(NavManager.Uri);
        return string.IsNullOrEmpty(relative) || relative.StartsWith("#") || relative.StartsWith("?");
    }
}
