@using System.Net.Http.Json
@using SantiagoConectaIA.Share.Objects.ConversationalModule
@using SantiagoConectaIA.Share.PostModels.ConversationalModule
@inject HttpClient Http
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<div class="chatbot-container @(isOpen ? "open" : "")">
    @if (isOpen)
    {
        <MudPaper Elevation="0" Class="chatbot-window">
            <!-- Fondo animado con gradiente super desenfocado -->
            <div class="chatbot-bg-layer"></div>
            <div class="chatbot-glass"></div>

            <!-- Sistema interactivo de partículas en Canvas desenfocado -->
            <canvas id="chat-canvas" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%; z-index: 1; pointer-events: none; opacity: 0.8; filter: blur(2px);"></canvas>

            <div class="chatbot-header d-flex justify-space-between align-center px-4 py-3">
                <div class="d-flex align-center">
                    <div class="ia-avatar-wrapper mr-3">
                        <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="color: #fff; font-size: 20px;" />
                    </div>
                    <div>
                        <MudText Typo="Typo.subtitle1" Style="font-weight: 700; color: #ffffff; letter-spacing: -0.5px;">Santiago Conecta IA</MudText>
                        <MudText Typo="Typo.caption" Style="color: #a5d6a7; font-weight: 500; display: flex; align-items: center; gap: 4px;">
                            <span class="online-dot"></span> En línea
                        </MudText>
                    </div>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.KeyboardArrowDown" Size="Size.Medium" OnClick="ToggleChat" Class="close-btn" />
            </div>

            <div class="chatbot-messages flex-grow-1 p-3">
                @if (messages.Count == 0)
                {
                    <div class="welcome-message text-center mt-5 mb-4">
                        <div class="welcome-icon-wrapper mb-3 d-flex justify-center">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="font-size: 32px; color: #ffffff;" />
                        </div>
                        <MudText Typo="Typo.h6" Style="font-weight: 700; color: #ffffff; text-shadow: 0 2px 4px rgba(0,0,0,0.2);">¡Hola!</MudText>
                        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.9); margin-top: 4px; text-shadow: 0 1px 2px rgba(0,0,0,0.1);">Soy tu asistente virtual inteligente. ¿Cómo puedo ayudarte hoy?</MudText>
                    </div>

                    <div class="suggestions-container mt-4 px-2">
                        <button class="suggestion-btn glass-btn" @onclick='() => SendQuickMessage("¿Cómo pago el impuesto predial?")'>
                            <span class="emoji">💳</span> Pago de Impuesto Predial
                        </button>
                        <button class="suggestion-btn glass-btn" @onclick='() => SendQuickMessage("Requisitos para copia de Acta de Nacimiento")'>
                            <span class="emoji">📄</span> Acta de Nacimiento
                        </button>
                        <button class="suggestion-btn glass-btn" @onclick='() => SendQuickMessage("¿Cuáles son los horarios de atención y oficinas?")'>
                            <span class="emoji">⏰</span> Oficinas y Horarios
                        </button>
                    </div>
                }
                
                @foreach (var msg in messages)
                {
                    <div class="message-wrapper d-flex @(msg.IsUser ? "justify-end" : "justify-start")">
                        @if (!msg.IsUser)
                        {
                            <div class="bot-avatar mr-2 mt-auto">
                                <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="font-size: 16px; color: #d81b60;" />
                            </div>
                        }
                        <div class="@($"{(msg.IsUser ? "user-msg" : "bot-msg")}")">
                            <MudText Typo="Typo.body2">@FormatMessage(msg.Content)</MudText>
                        </div>
                    </div>
                }
                
                @if (isLoading)
                {
                    <div class="message-wrapper d-flex justify-start">
                        <div class="bot-avatar mr-2 mt-auto">
                            <MudIcon Icon="@Icons.Material.Filled.AutoAwesome" Style="font-size: 16px; color: #d81b60;" />
                        </div>
                        <div class="bot-msg typing-msg">
                            <div class="typing-indicator">
                                <span></span><span></span><span></span>
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="chatbot-input-container">
                <div class="chatbot-input-wrapper">
                    <MudTextField @bind-Value="currentMessage" Placeholder="Pregúntale a la IA..." DisableUnderLine="true" 
                                   Variant="Variant.Text" Margin="Margin.Dense" Class="flex-grow-1 custom-input"
                                   OnKeyDown="HandleKeyDown" Disabled="isLoading" Immediate="true" />
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Color="Color.Inherit" 
                                   Disabled="@(isLoading || string.IsNullOrWhiteSpace(currentMessage))" 
                                   OnClick="SendMessage" Class="send-btn" Size="Size.Small" />
                </div>
            </div>
        </MudPaper>
    }
    else
    {
        <div class="chatbot-fab">
            <MudFab Color="Color.Primary" Size="Size.Large" OnClick="ToggleChat" Class="pulse-animation custom-fab" StartIcon="@Icons.Material.Filled.AutoAwesome" />
        </div>
    }
</div>

<style>
    .chatbot-container {
        position: fixed;
        bottom: 0;
        right: 0;
        z-index: 9999;
        font-family: 'Inter', 'Roboto', sans-serif;
        pointer-events: none;
    }
    
    .chatbot-container.open {
        top: 0;
        left: 0;
        pointer-events: auto;
    }
    
    .chatbot-window {
        position: absolute;
        top: 16px;
        right: 16px;
        bottom: 16px;
        width: 420px;
        max-width: calc(100vw - 32px); /* Never overflow the screen */
        display: flex;
        flex-direction: column;
        box-shadow: 0 12px 48px rgba(0,0,0,0.2) !important;
        transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1), opacity 0.4s ease;
        animation: slideUpFade 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        border-radius: 24px !important;
        background: transparent !important;
        border: 1px solid rgba(255,255,255,0.2);
        overflow: hidden;
        box-sizing: border-box; /* Previene desbordamiento por padding */
    }

    /* EFECTO FONDO ANIMADO Y SUPER DESENFOCADO */
    .chatbot-bg-layer {
        position: absolute;
        top: -50%; left: -50%; right: -50%; bottom: -50%;
        background: linear-gradient(-45deg, #880e4f, #d81b60, #4a148c, #c2185b);
        background-size: 400% 400%;
        animation: gradientChat 15s ease infinite;
        filter: blur(60px); 
        z-index: 0;
    }

    .chatbot-glass {
        position: absolute;
        top: 0; left: 0; right: 0; bottom: 0;
        background: rgba(255, 255, 255, 0.05); 
        backdrop-filter: blur(30px);
        -webkit-backdrop-filter: blur(30px);
        z-index: 1;
    }

    @@keyframes gradientChat {
        0% { background-position: 0% 50%; }
        50% { background-position: 100% 50%; }
        100% { background-position: 0% 50%; }
    }

    /* Asegurar que el contenido del chat flote por encima del fondo */
    .chatbot-header, .chatbot-messages, .chatbot-input-container {
        position: relative;
        z-index: 2;
    }

    .chatbot-header {
        background: rgba(255,255,255,0.05);
        border-bottom: 1px solid rgba(255,255,255,0.15);
        padding-top: 20px !important;
        padding-bottom: 16px !important;
    }

    .ia-avatar-wrapper {
        width: 36px;
        height: 36px;
        border-radius: 50%;
        background: rgba(255,255,255,0.2);
        backdrop-filter: blur(10px);
        border: 1px solid rgba(255,255,255,0.3);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    .online-dot {
        width: 8px;
        height: 8px;
        background-color: #69f0ae;
        border-radius: 50%;
        display: inline-block;
        box-shadow: 0 0 0 2px rgba(105, 240, 174, 0.2);
    }

    .close-btn {
        background: rgba(255,255,255,0.2) !important;
        color: #ffffff !important;
        transition: background 0.2s ease, transform 0.2s ease;
        border-radius: 50% !important;
    }
    .close-btn:hover {
        background: rgba(255,255,255,0.35) !important;
        transform: scale(1.05);
    }

    .chatbot-messages {
        overflow-y: auto;
        overflow-x: hidden;
        display: flex;
        flex-direction: column;
        gap: 16px;
        background: transparent;
        scroll-behavior: smooth;
        width: 100%;
        box-sizing: border-box;
    }
    
    .chatbot-messages::-webkit-scrollbar { width: 6px; }
    .chatbot-messages::-webkit-scrollbar-track { background: transparent; }
    .chatbot-messages::-webkit-scrollbar-thumb { background-color: rgba(255,255,255,0.3); border-radius: 10px; }

    .message-wrapper {
        margin-bottom: 8px;
    }

    .user-msg {
        background: rgba(255, 255, 255, 0.9);
        color: #1a1a1a;
        border-radius: 20px 20px 4px 20px;
        padding: 12px 16px;
        max-width: 80%;
        word-break: break-word;
        font-size: 0.95rem;
        line-height: 1.5;
        box-shadow: 0 2px 8px rgba(0,0,0,0.05);
    }

    .bot-msg {
        background: rgba(255, 255, 255, 0.85);
        color: #1a1a1a;
        border-radius: 20px 20px 20px 4px;
        padding: 12px 16px;
        max-width: 85%;
        word-break: break-word;
        border: 1px solid rgba(255,255,255,0.5);
        box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        font-size: 0.95rem;
        line-height: 1.6;
        backdrop-filter: blur(10px);
    }
    
    .typing-msg {
        padding: 16px;
    }

    .bot-avatar {
        width: 24px;
        height: 24px;
        border-radius: 50%;
        background: #fce4ec;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
    }

    .chatbot-input-container {
        padding: 16px;
        background: linear-gradient(to top, rgba(0,0,0,0.3) 10%, rgba(0,0,0,0));
        width: 100%;
        box-sizing: border-box;
    }

    .chatbot-input-wrapper {
        display: flex;
        align-items: flex-end;
        background: rgba(255, 255, 255, 0.9);
        border-radius: 24px;
        padding: 6px 6px 6px 16px;
        border: 1px solid rgba(255,255,255,0.5);
        transition: border-color 0.3s ease, background 0.3s ease;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
        width: 100%;
        box-sizing: border-box;
    }
    
    .chatbot-input-wrapper:focus-within {
        background: #ffffff;
        border-color: rgba(255, 255, 255, 0.8);
        box-shadow: 0 0 0 4px rgba(255, 255, 255, 0.2);
    }

    .custom-input { margin-top: 0 !important; }
    
    .custom-input input {
        padding: 10px 0 !important;
        font-size: 0.95rem !important;
        color: #1a1a1a !important;
    }

    .send-btn {
        background: #d81b60 !important;
        color: white !important;
        border-radius: 50% !important;
        width: 36px;
        height: 36px;
        margin-left: 8px;
        transition: transform 0.2s ease;
    }
    .send-btn:disabled {
        background: rgba(0,0,0,0.1) !important;
        color: rgba(0,0,0,0.3) !important;
    }
    .send-btn:not(:disabled):hover {
        transform: scale(1.05);
        background: #c2185b !important;
    }

    .chatbot-fab {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
        pointer-events: auto;
    }
    
    .custom-fab {
        background: linear-gradient(135deg, #d81b60, #880e4f) !important;
        width: 64px !important;
        height: 64px !important;
        box-shadow: 0 8px 24px rgba(216, 27, 96, 0.3) !important;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275) !important;
    }
    
    .custom-fab:hover {
        transform: scale(1.08) !important;
    }
    
    .pulse-animation {
        animation: pulse 2.5s infinite;
    }
    
    @@keyframes pulse {
        0% { box-shadow: 0 0 0 0 rgba(216, 27, 96, 0.5); }
        70% { box-shadow: 0 0 0 20px rgba(216, 27, 96, 0); }
        100% { box-shadow: 0 0 0 0 rgba(216, 27, 96, 0); }
    }

    @@keyframes slideUpFade {
        from { opacity: 0; transform: translateY(20px) scale(0.95); }
        to { opacity: 1; transform: translateY(0) scale(1); }
    }
    
    .typing-indicator {
        display: flex;
        align-items: center;
        gap: 6px;
    }
    .typing-indicator span {
        width: 6px;
        height: 6px;
        background-color: #d81b60;
        border-radius: 50%;
        animation: typing 1.4s infinite both;
        opacity: 0.6;
    }
    .typing-indicator span:nth-child(1) { animation-delay: 0s; }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
    
    @@keyframes typing {
        0%, 80%, 100% { transform: translateY(0); }
        40% { transform: translateY(-4px); }
    }

    .suggestions-container {
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .glass-btn {
        background: rgba(255, 255, 255, 0.15) !important;
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        color: #ffffff !important;
        text-shadow: 0 1px 2px rgba(0,0,0,0.2);
        backdrop-filter: blur(5px);
        border-radius: 24px !important;
        padding: 10px 16px !important;
        font-weight: 500;
        transition: all 0.2s ease;
    }
    .glass-btn:hover {
        background: rgba(255, 255, 255, 0.25) !important;
        border-color: rgba(255, 255, 255, 0.4) !important;
        transform: translateY(-2px);
    }

    @@media (max-width: 768px) {
        .chatbot-container.open {
            background: rgba(0,0,0,0.6);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
        }
        
        .chatbot-window {
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            width: 100%;
            height: 100%;
            max-width: 100%;
            border-radius: 0 !important;
            border: none;
            box-shadow: none !important;
            animation: slideUpMobile 0.3s cubic-bezier(0.16, 1, 0.3, 1);
        }

        .chatbot-input-container {
            padding: 12px 16px env(safe-area-inset-bottom, 16px);
            background: linear-gradient(to top, rgba(0,0,0,0.5) 30%, rgba(0,0,0,0));
            border-top: none;
        }
    }
    
    @@keyframes slideUpMobile {
        from { transform: translateY(100%); }
        to { transform: translateY(0); }
    }
</style>

@code {
    private bool isOpen = false;
    private string currentMessage = "";
    private bool isLoading = false;
    private string threadId = "";
    private List<ChatMessage> messages = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                threadId = await JS.InvokeAsync<string>("localStorage.getItem", "chatThreadId");
                if (string.IsNullOrEmpty(threadId))
                {
                    threadId = Guid.NewGuid().ToString();
                    await JS.InvokeVoidAsync("localStorage.setItem", "chatThreadId", threadId);
                }
            }
            catch
            {
                // Fallback in case JS interop fails (e.g., prerendering)
                if (string.IsNullOrEmpty(threadId)) threadId = Guid.NewGuid().ToString();
            }
        }
    }

    private async Task ToggleChat()
    {
        isOpen = !isOpen;
        if (isOpen)
        {
            await ScrollToBottom();
            _ = InitParticlesAsync();
        }
    }

    private async Task InitParticlesAsync()
    {
        try
        {
            await Task.Delay(100);
            var script = @"
                const canvas = document.getElementById('chat-canvas');
                if (canvas) {
                    const ctx = canvas.getContext('2d');
                    let width = canvas.parentElement.clientWidth;
                    let height = canvas.parentElement.clientHeight;
                    canvas.width = width;
                    canvas.height = height;
                    
                    window.addEventListener('resize', () => {
                        width = canvas.parentElement.clientWidth;
                        height = canvas.parentElement.clientHeight;
                        canvas.width = width;
                        canvas.height = height;
                    });

                    let particles = [];
                    class Particle {
                        constructor() {
                            this.x = Math.random() * width;
                            this.y = Math.random() * height;
                            this.vx = (Math.random() - 0.5) * 1.5;
                            this.vy = (Math.random() - 0.5) * 1.5;
                            this.radius = Math.random() * 2 + 1;
                        }
                        update() {
                            this.x += this.vx;
                            this.y += this.vy;
                            if (this.x < 0 || this.x > width) this.vx *= -1;
                            if (this.y < 0 || this.y > height) this.vy *= -1;
                        }
                        draw() {
                            ctx.beginPath();
                            ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
                            ctx.fillStyle = 'rgba(255, 255, 255, 0.8)';
                            ctx.fill();
                        }
                    }

                    for (let i = 0; i < 40; i++) particles.push(new Particle());

                    function animate() {
                        if (!document.getElementById('chat-canvas')) return;
                        ctx.clearRect(0, 0, width, height);
                        
                        for(let i=0; i<particles.length; i++){
                            particles[i].update();
                            particles[i].draw();
                            for(let j=i; j<particles.length; j++){
                                let dx = particles[i].x - particles[j].x;
                                let dy = particles[i].y - particles[j].y;
                                let dist = Math.sqrt(dx*dx + dy*dy);
                                if(dist < 100){
                                    ctx.beginPath();
                                    ctx.strokeStyle = `rgba(255,255,255,${0.3 - dist/333})`;
                                    ctx.lineWidth = 1;
                                    ctx.moveTo(particles[i].x, particles[i].y);
                                    ctx.lineTo(particles[j].x, particles[j].y);
                                    ctx.stroke();
                                }
                            }
                        }
                        requestAnimationFrame(animate);
                    }
                    animate();
                }
            ";
            await JS.InvokeVoidAsync("eval", script);
        }
        catch { }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await Task.Delay(50); // Pequeño delay para dejar que Blazor renderice el nuevo nodo
            await JS.InvokeVoidAsync("eval", "const el = document.querySelector('.chatbot-messages'); if (el) el.scrollTop = el.scrollHeight;");
        }
        catch { }
    }

    private async Task SendQuickMessage(string question)
    {
        currentMessage = question;
        await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentMessage) || isLoading) return;

        var userQuery = currentMessage;
        currentMessage = "";
        
        messages.Add(new ChatMessage { Content = userQuery, IsUser = true, Timestamp = DateTime.Now });
        isLoading = true;
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            var request = new PostChatRequest 
            { 
                nvchUserQuery = userQuery, 
                nvchUserId = threadId 
            };
            
            var response = await Http.PostAsJsonAsync("api/Chat/PostSearchForChat", request);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ChatResponseIA>();
                if (result != null && !string.IsNullOrEmpty(result.nvchAgenteResponse))
                {
                    messages.Add(new ChatMessage { Content = result.nvchAgenteResponse, IsUser = false, Timestamp = DateTime.Now });
                }
                else
                {
                    messages.Add(new ChatMessage { Content = "Lo siento, recibí una respuesta vacía.", IsUser = false, Timestamp = DateTime.Now });
                }
            }
            else
            {
                messages.Add(new ChatMessage { Content = "Lo siento, hubo un problema al comunicar con el servidor.", IsUser = false, Timestamp = DateTime.Now });
            }
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage { Content = "Ocurrió un error al procesar tu solicitud.", IsUser = false, Timestamp = DateTime.Now });
            Console.WriteLine($"Error chat: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private MarkupString FormatMessage(string content)
    {
        if (string.IsNullOrEmpty(content)) return (MarkupString)"";

        // 1. Escapar HTML para evitar inyecciones XSS
        string encoded = System.Net.WebUtility.HtmlEncode(content);

        // 2. Convertir saltos de línea a <br />
        encoded = encoded.Replace("\n", "<br />");

        // 3. Convertir negritas (**texto**) a <strong>texto</strong>
        encoded = System.Text.RegularExpressions.Regex.Replace(encoded, @"\*\*(.*?)\*\*", "<strong>$1</strong>");

        // 4. Convertir viñetas (* o • al inicio de línea)
        encoded = System.Text.RegularExpressions.Regex.Replace(encoded, @"(<br\s*/?>|^)\s*[•\*\-]\s+", "$1&bull; ");

        // 5. Convertir enlaces markdown [texto](url) a <a href="url" target="_blank">texto</a>
        encoded = System.Text.RegularExpressions.Regex.Replace(encoded, @"\[(.*?)\]\((.*?)\)", m => 
        {
            var label = m.Groups[1].Value;
            var url = System.Net.WebUtility.HtmlDecode(m.Groups[2].Value);
            return $"<a href=\"{url}\" target=\"_blank\" style=\"color: #d81b60; font-weight: bold; text-decoration: underline;\">{label}</a>";
        });

        return new MarkupString(encoded);
    }

    public class ChatMessage
    {
        public string Content { get; set; } = "";
        public bool IsUser { get; set; }
        public DateTime Timestamp { get; set; }
    }
    
    public class PostChatRequest
    {
        public string nvchUserQuery { get; set; } = "";
        public string nvchUserId { get; set; } = "";
    }
}
