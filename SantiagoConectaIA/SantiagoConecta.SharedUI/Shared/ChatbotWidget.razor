@using System.Net.Http.Json
@using SantiagoConectaIA.Share.Objects.ConversationalModule
@using SantiagoConectaIA.Share.PostModels.ConversationalModule
@inject HttpClient Http
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<div class="chatbot-container">
    @if (isOpen)
    {
        <MudPaper Elevation="8" Class="chatbot-window d-flex flex-column" Style="border-radius: 16px; overflow: hidden; background: rgba(255, 255, 255, 0.95); backdrop-filter: blur(10px);">
            <div class="chatbot-header d-flex justify-space-between align-center px-4 py-3" style="background: linear-gradient(135deg, #d81b60, #880e4f); color: white;">
                <div class="d-flex align-center">
                    <MudAvatar Color="Color.Transparent" Size="Size.Small" Class="mr-2">
                        <MudIcon Icon="@Icons.Material.Filled.SmartToy" Color="Color.Inherit" />
                    </MudAvatar>
                    <MudText Typo="Typo.subtitle1" Style="font-weight: 600;">Santiago Conecta IA</MudText>
                </div>
                <MudIconButton Icon="@Icons.Material.Filled.Close" Color="Color.Inherit" Size="Size.Small" OnClick="ToggleChat" />
            </div>

            <div class="chatbot-messages flex-grow-1 p-3" style="overflow-y: auto; display: flex; flex-direction: column; gap: 12px; background-color: #f8f9fa;">
                @if (messages.Count == 0)
                {
                    <div class="text-center mt-3 text-muted">
                        <MudIcon Icon="@Icons.Material.Filled.ChatBubbleOutline" Size="Size.Large" Style="opacity: 0.5;" />
                        <MudText Typo="Typo.body2" Class="mt-2">¡Hola! Soy tu asistente virtual. ¿En qué te puedo ayudar hoy?</MudText>
                    </div>

                    <div class="d-flex flex-column gap-2 mt-4 px-2">
                        <button class="suggestion-btn" @onclick='() => SendQuickMessage("¿Cómo pago el impuesto predial?")'>
                            🏠 Pago de Impuesto Predial
                        </button>
                        <button class="suggestion-btn" @onclick='() => SendQuickMessage("Requisitos para copia de Acta de Nacimiento")'>
                            📄 Acta de Nacimiento
                        </button>
                        <button class="suggestion-btn" @onclick='() => SendQuickMessage("¿Cuáles son los horarios de atención y oficinas?")'>
                            ⏰ Oficinas y Horarios
                        </button>
                    </div>
                }
                
                @foreach (var msg in messages)
                {
                    <div class="d-flex @(msg.IsUser ? "justify-end" : "justify-start")">
                        <MudPaper Elevation="1" Class="@($"{(msg.IsUser ? "user-msg" : "bot-msg")} px-3 py-2")" 
                                  Style="@(msg.IsUser ? "background: linear-gradient(135deg, #e91e63, #c2185b); color: white; border-radius: 16px 16px 0 16px; max-width: 85%; word-break: break-word;" : "background: #ffffff; color: #333; border-radius: 16px 16px 16px 0; max-width: 85%; word-break: break-word; border: 1px solid #e0e0e0;")">
                            <MudText Typo="Typo.body2">@FormatMessage(msg.Content)</MudText>
                        </MudPaper>
                    </div>
                }
                
                @if (isLoading)
                {
                    <div class="d-flex justify-start">
                        <MudPaper Elevation="0" Class="px-3 py-2" Style="background: transparent;">
                            <div class="typing-indicator">
                                <span></span><span></span><span></span>
                            </div>
                        </MudPaper>
                    </div>
                }
            </div>

            <div class="chatbot-input p-2 d-flex align-center" style="border-top: 1px solid #eeeeee; background: white;">
                <MudTextField @bind-Value="currentMessage" Placeholder="Escribe un mensaje..." DisableUnderLine="true" 
                               Variant="Variant.Outlined" Margin="Margin.Dense" Class="flex-grow-1"
                               OnKeyDown="HandleKeyDown" Disabled="isLoading" Style="border-radius: 20px; background-color: #f5f5f5;" />
                <MudIconButton Icon="@Icons.Material.Filled.Send" Color="Color.Primary" Disabled="@(isLoading)" OnClick="SendMessage" Class="ml-1" />
            </div>
        </MudPaper>
    }
    else
    {
        <div class="chatbot-fab">
            <MudFab Color="Color.Primary" StartIcon="@Icons.Material.Filled.Chat" Size="Size.Large" OnClick="ToggleChat" Class="pulse-animation" Style="background: linear-gradient(135deg, #d81b60, #880e4f);" />
        </div>
    }
</div>

<style>
    .chatbot-container {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        z-index: 9999;
        font-family: 'Inter', 'Roboto', sans-serif;
    }
    
    .chatbot-window {
        position: absolute;
        top: 0;
        right: 0;
        width: 33.33vw;
        min-width: 400px;
        height: 100vh;
        box-shadow: -5px 0 40px rgba(0,0,0,0.15) !important;
        transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        animation: slideInRight 0.3s ease-out;
        border-radius: 0 !important;
    }

    .chatbot-fab {
        position: fixed;
        bottom: 24px;
        right: 24px;
        z-index: 9999;
    }
    
    .pulse-animation {
        box-shadow: 0 0 0 0 rgba(216, 27, 96, 0.7);
        animation: pulse 2s infinite;
    }
    
    @@keyframes pulse {
        0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(216, 27, 96, 0.7); }
        70% { transform: scale(1); box-shadow: 0 0 0 15px rgba(216, 27, 96, 0); }
        100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(216, 27, 96, 0); }
    }

    @@keyframes slideInRight {
        from { opacity: 0; transform: translateX(100%); }
        to { opacity: 1; transform: translateX(0); }
    }
    
    .typing-indicator {
        display: flex;
        align-items: center;
        gap: 4px;
        padding: 8px 12px;
        background: #f0f0f0;
        border-radius: 12px;
        width: fit-content;
    }
    .typing-indicator span {
        width: 6px;
        height: 6px;
        background-color: #90a4ae;
        border-radius: 50%;
        animation: typing 1.4s infinite both;
    }
    .typing-indicator span:nth-child(1) { animation-delay: 0s; }
    .typing-indicator span:nth-child(2) { animation-delay: 0.2s; }
    .typing-indicator span:nth-child(3) { animation-delay: 0.4s; }
    
    @@keyframes typing {
        0%, 80%, 100% { transform: translateY(0); }
        40% { transform: translateY(-5px); }
    }

    .suggestion-btn {
        background: #ffffff;
        border: 1px solid #e0e0e0;
        border-radius: 12px;
        padding: 10px 14px;
        font-size: 0.9rem;
        color: #d81b60;
        text-align: left;
        cursor: pointer;
        transition: all 0.2s ease;
        font-weight: 500;
        box-shadow: 0 2px 6px rgba(0,0,0,0.02);
    }
    .suggestion-btn:hover {
        background: #fce4ec;
        border-color: #f8bbd0;
        transform: translateY(-1px);
        box-shadow: 0 4px 10px rgba(216, 27, 96, 0.08);
    }

    @@media (max-width: 768px) {
        .chatbot-window {
            width: 100vw;
            min-width: unset;
        }
    }
</style>

@code {
    private bool isOpen = false;
    private string currentMessage = "";
    private bool isLoading = false;
    private string threadId = "";
    private List<ChatMessage> messages = new();

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                threadId = await JS.InvokeAsync<string>("localStorage.getItem", "chatThreadId");
                if (string.IsNullOrEmpty(threadId))
                {
                    threadId = Guid.NewGuid().ToString();
                    await JS.InvokeVoidAsync("localStorage.setItem", "chatThreadId", threadId);
                }
            }
            catch
            {
                // Fallback in case JS interop fails (e.g., prerendering)
                if (string.IsNullOrEmpty(threadId)) threadId = Guid.NewGuid().ToString();
            }
        }
    }

    private async Task ToggleChat()
    {
        isOpen = !isOpen;
        if (isOpen)
        {
            await ScrollToBottom();
        }
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessage();
        }
    }

    private async Task ScrollToBottom()
    {
        try
        {
            await Task.Delay(50); // Pequeño delay para dejar que Blazor renderice el nuevo nodo
            await JS.InvokeVoidAsync("eval", "const el = document.querySelector('.chatbot-messages'); if (el) el.scrollTop = el.scrollHeight;");
        }
        catch { }
    }

    private async Task SendQuickMessage(string question)
    {
        currentMessage = question;
        await SendMessage();
    }

    private async Task SendMessage()
    {
        if (string.IsNullOrWhiteSpace(currentMessage) || isLoading) return;

        var userQuery = currentMessage;
        currentMessage = "";
        
        messages.Add(new ChatMessage { Content = userQuery, IsUser = true, Timestamp = DateTime.Now });
        isLoading = true;
        StateHasChanged();
        await ScrollToBottom();

        try
        {
            var request = new PostChatRequest 
            { 
                nvchUserQuery = userQuery, 
                nvchUserId = threadId 
            };
            
            var response = await Http.PostAsJsonAsync("api/Chat/PostSearchForChat", request);
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<ChatResponseIA>();
                if (result != null && !string.IsNullOrEmpty(result.nvchAgenteResponse))
                {
                    messages.Add(new ChatMessage { Content = result.nvchAgenteResponse, IsUser = false, Timestamp = DateTime.Now });
                }
                else
                {
                    messages.Add(new ChatMessage { Content = "Lo siento, recibí una respuesta vacía.", IsUser = false, Timestamp = DateTime.Now });
                }
            }
            else
            {
                messages.Add(new ChatMessage { Content = "Lo siento, hubo un problema al comunicar con el servidor.", IsUser = false, Timestamp = DateTime.Now });
            }
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage { Content = "Ocurrió un error al procesar tu solicitud.", IsUser = false, Timestamp = DateTime.Now });
            Console.WriteLine($"Error chat: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
            await ScrollToBottom();
        }
    }

    private MarkupString FormatMessage(string content)
    {
        if (string.IsNullOrEmpty(content)) return (MarkupString)"";

        // 1. Escapar HTML para evitar inyecciones XSS
        string encoded = System.Net.WebUtility.HtmlEncode(content);

        // 2. Convertir saltos de línea a <br />
        encoded = encoded.Replace("\n", "<br />");

        // 3. Convertir negritas (**texto**) a <strong>texto</strong>
        encoded = System.Text.RegularExpressions.Regex.Replace(encoded, @"\*\*(.*?)\*\*", "<strong>$1</strong>");

        // 4. Convertir viñetas (* o • al inicio de línea)
        encoded = System.Text.RegularExpressions.Regex.Replace(encoded, @"(<br\s*/?>|^)\s*[•\*\-]\s+", "$1&bull; ");

        // 5. Convertir enlaces markdown [texto](url) a <a href="url" target="_blank">texto</a>
        encoded = System.Text.RegularExpressions.Regex.Replace(encoded, @"\[(.*?)\]\((.*?)\)", m => 
        {
            var label = m.Groups[1].Value;
            var url = System.Net.WebUtility.HtmlDecode(m.Groups[2].Value);
            return $"<a href=\"{url}\" target=\"_blank\" style=\"color: #d81b60; font-weight: bold; text-decoration: underline;\">{label}</a>";
        });

        return new MarkupString(encoded);
    }

    public class ChatMessage
    {
        public string Content { get; set; } = "";
        public bool IsUser { get; set; }
        public DateTime Timestamp { get; set; }
    }
    
    public class PostChatRequest
    {
        public string nvchUserQuery { get; set; } = "";
        public string nvchUserId { get; set; } = "";
    }
}
