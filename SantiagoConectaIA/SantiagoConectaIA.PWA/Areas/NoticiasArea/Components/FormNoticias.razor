@using SantiagoConectaIA.PWA.Areas.NoticiasArea.Utiles
@using SantiagoConectaIA.PWA.Shared.Workspace
@inherits EngramaWorkspaceComponent
@inject ISnackbar Snackbar
@using MudBlazor

<EditForm Model="@Data.NoticiaSelected" OnValidSubmit="Submit">
    <DataAnnotationsValidator />
    <MudCard>
        <MudTabs Elevation="0" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-4">
            
            @* --- TAB 1: INFORMACIÓN GENERAL --- *@
            <MudTabPanel Text="Información General" Icon="@Icons.Material.Filled.Article">
                <MudGrid>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Data.NoticiaSelected.vchTitulo" Label="Título (Español)" Variant="Variant.Outlined" Class="mb-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        <MudTextField @bind-Value="Data.NoticiaSelected.nvchContenido" Label="Contenido (Español)" Variant="Variant.Outlined" Lines="5" Class="mb-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudTextField @bind-Value="Data.NoticiaSelected.vchTituloEn" Label="Title (English)" Variant="Variant.Outlined" Class="mb-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        <MudTextField @bind-Value="Data.NoticiaSelected.nvchContenidoEn" Label="Content (English)" Variant="Variant.Outlined" Lines="5" Class="mb-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        @* Llenar con API de Categorías *@
                        <MudSelect T="int?" @bind-Value="Data.NoticiaSelected.iIdCategoria" Label="Categoría" Variant="Variant.Outlined" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)">
                            <MudSelectItem T="int?" Value="1">Comunicado Oficial</MudSelectItem>
                            <MudSelectItem T="int?" Value="2">Cultura</MudSelectItem>
                            <MudSelectItem T="int?" Value="3">Deportes</MudSelectItem>
                            <MudSelectItem T="int?" Value="4">Policiaca</MudSelectItem>
                        </MudSelect>
                    </MudItem>
                    <MudItem xs="12" sm="6">
                        <MudCheckBox T="bool" @bind-Value="Data.NoticiaSelected.bActivo" Label="Noticia Activa" Color="Color.Primary" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)"></MudCheckBox>
                    </MudItem>
                </MudGrid>
            </MudTabPanel>

            <MudTabPanel Text="Bloques / Metadatos" Icon="@Icons.Material.Filled.Extension">
                <TabMetadatosNoticias Data="Data" EstadoControl="EstadoControl" />
            </MudTabPanel>
        </MudTabs>
    </MudCard>
</EditForm>
