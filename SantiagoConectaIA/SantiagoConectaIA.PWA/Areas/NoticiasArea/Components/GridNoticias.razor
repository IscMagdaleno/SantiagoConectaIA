@using SantiagoConectaIA.PWA.Areas.NoticiasArea.Components
@using SantiagoConectaIA.PWA.Areas.NoticiasArea.Utiles
@using SantiagoConectaIA.PWA.Shared.Workspace
@inherits EngramaWorkspaceComponent

    @* HEADER / NAVIGATION *@
    <MudGrid Justify="Justify.SpaceBetween" Class="mb-4">
        <MudItem>
            <MudText Typo="Typo.h4" Style="color: #A50A3A; font-weight: bold;">
                Noticias
            </MudText>
        </MudItem>
    </MudGrid>
 
    @* CONTENT *@
    <MudGrid>
            @if (Data != null && Data.LstNoticias != null)
            {
               <MudItem xs="12">
                   <MudTextField @bind-Value="filtroTexto"
                                  Label="Buscar Noticia"
                                  Variant="Variant.Outlined"
                                  Immediate="true"
                                  Adornment="Adornment.End"
                                  AdornmentIcon="@Icons.Material.Filled.Search"
                                  Class="mb-4" />
               </MudItem>
                 
                @foreach (var noticia in NoticiasFiltradas)
                {
                    <MudItem xs="12" sm="6" md="4" lg="3">
                        <NoticiaCardComponent Noticia="@noticia" 
                                              OnView="OnViewNoticia" 
                                              OnEdit="OnEditNoticia" 
                                              OnDelete="OnDeleteNoticia" />
                    </MudItem>
                }
                 
                @if (!NoticiasFiltradas.Any())
                {
                     <MudItem xs="12">
                        <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                            @if(string.IsNullOrEmpty(filtroTexto)) { <text>No hay noticias registradas.</text> }
                            else { <text>No se encontraron noticias que coincidan con "@filtroTexto".</text> }
                        </MudAlert>
                    </MudItem>
                }
            }
            else
            {
                <MudItem xs="12">
                    <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                </MudItem>
            }
        </MudGrid>
