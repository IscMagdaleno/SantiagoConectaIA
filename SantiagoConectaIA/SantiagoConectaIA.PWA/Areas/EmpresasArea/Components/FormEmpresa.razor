@using SantiagoConectaIA.PWA.Areas.EmpresasArea.Utiles
@using SantiagoConectaIA.PWA.Shared.Workspace
@inherits EngramaWorkspaceComponent

<MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
    <MudTabPanel Text="Datos Generales" Icon="@Icons.Material.Filled.Info">
        <MudCard Elevation="0">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Información de la Empresa</MudText>
                @if (Data != null && Data.RegistroSeleccionado != null)
                {
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Data.RegistroSeleccionado.vchNombreComercial"
                                          Label="Nombre Comercial" 
                                          Variant="Variant.Outlined" 
                                          Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        </MudItem>
                        
                        <MudItem xs="12" sm="6">
                            <MudSelect T="int?" @bind-Value="Data.RegistroSeleccionado.iIdCatalogoEmpresa"
                                       Label="Categoría (Giro)" 
                                       Variant="Variant.Outlined" 
                                       Disabled="@(EstadoControl == TipoEstadoControl.Lectura)"
                                       AnchorOrigin="Origin.BottomCenter">
                                @foreach (var cat in Data.LstCatalogos)
                                {
                                    <MudSelectItem T="int?" Value="@((int?)cat.iIdCatalogoEmpresa)">@cat.vchNombre</MudSelectItem>
                                }
                            </MudSelect>
                        </MudItem>
                        
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Data.RegistroSeleccionado.vchSlogan"
                                          Label="Eslogan" 
                                          Variant="Variant.Outlined" 
                                          Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="Data.RegistroSeleccionado.nvchDescripcion"
                                          Label="Descripción" 
                                          Variant="Variant.Outlined" 
                                          Lines="3"
                                          Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Data.RegistroSeleccionado.vchTelefono"
                                          Label="Teléfono" 
                                          Variant="Variant.Outlined" 
                                          Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="Data.RegistroSeleccionado.vchCorreo"
                                          Label="Correo Electrónico" 
                                          Variant="Variant.Outlined" 
                                          Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            @if (!string.IsNullOrEmpty(Data.RegistroSeleccionado.vchLogoUrl))
                            {
                                <MudImage Src="@Data.RegistroSeleccionado.vchLogoUrl" Height="80" Class="rounded-lg mb-2" ObjectFit="ObjectFit.Contain" />
                            }
                            <MudFileUpload T="IBrowserFile" Accept=".png, .jpg, .jpeg" FilesChanged="UploadLogo" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)">
                                <ActivatorContent>
                                    <MudButton Variant="Variant.Outlined" Color="Color.Primary" StartIcon="@Icons.Material.Filled.CloudUpload" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)">
                                        Subir Logo
                                    </MudButton>
                                </ActivatorContent>
                            </MudFileUpload>
                        </MudItem>
                    </MudGrid>
                }
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="Misión y Visión" Icon="@Icons.Material.Filled.Assignment">
        <MudCard Elevation="0">
            <MudCardContent>
                @if (Data != null && Data.RegistroSeleccionado != null)
                {
                    <MudGrid>
                        <MudItem xs="12">
                            <MudTextField @bind-Value="Data.RegistroSeleccionado.nvchMision"
                                          Label="Misión" 
                                          Variant="Variant.Outlined" 
                                          Lines="3"
                                          Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        </MudItem>

                        <MudItem xs="12">
                            <MudTextField @bind-Value="Data.RegistroSeleccionado.nvchVision"
                                          Label="Visión" 
                                          Variant="Variant.Outlined" 
                                          Lines="3"
                                          Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        </MudItem>
                    </MudGrid>
                }
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="Ubicaciones" Icon="@Icons.Material.Filled.Map" Disabled="@(Data.RegistroSeleccionado.iIdEmpresa <= 0)">
        <MudCard Elevation="0">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Ubicaciones de la Empresa</MudText>
                <TabUbicaciones />
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="Redes Sociales" Icon="@Icons.Material.Filled.Share" Disabled="@(Data.RegistroSeleccionado.iIdEmpresa <= 0)">
        <MudCard Elevation="0">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Redes Sociales</MudText>
                <TabRedesSociales />
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="Servicios" Icon="@Icons.Material.Filled.Storefront" Disabled="@(Data.RegistroSeleccionado.iIdEmpresa <= 0)">
        <MudCard Elevation="0">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Servicios y Categorías</MudText>
                <TabServicios />
            </MudCardContent>
        </MudCard>
    </MudTabPanel>

    <MudTabPanel Text="Personalización" Icon="@Icons.Material.Filled.Palette" Disabled="@(Data.RegistroSeleccionado.iIdEmpresa <= 0)">
        <MudCard Elevation="0">
            <MudCardContent>
                <MudText Typo="Typo.h6" Class="mb-4">Configuración Visual (Branding)</MudText>
                <TabConfiguracionVisual EstadoControl="@EstadoControl" />
            </MudCardContent>
        </MudCard>
    </MudTabPanel>
</MudTabs>
