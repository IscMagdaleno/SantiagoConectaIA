@using SantiagoConectaIA.Share.Objects.OficinasModule
@inherits EngramaComponent
@inject IDialogService DialogService

<MudCard Class="service-card" Style="height: 100%; display: flex; flex-direction: column;">
    <MudCardContent Style="text-align: center; padding: 2rem; flex-grow: 1;">
        <div class="card-icon-container">
            <MudIcon Icon="@Icons.Material.Filled.Business"
                     Size="Size.Large"
                     Class="card-icon"
                     Style="color: #A50A3A;" />
        </div>

        <MudText Typo="Typo.h5" Style="color: #333333; font-weight: bold; margin: 1rem 0;">
            @Oficina.vchNombre
        </MudText>

        <MudText Typo="Typo.body2" Style="color: #666666; line-height: 1.6;">
            <MudIcon Icon="@Icons.Material.Filled.LocationOn" Size="Size.Small" Class="mr-1" /> @Oficina.vchDireccion
        </MudText>
        
        @if(!string.IsNullOrEmpty(Oficina.vchTelefono))
        {
            <MudText Typo="Typo.body2" Style="color: #666666;" Class="mt-1">
                <MudIcon Icon="@Icons.Material.Filled.Phone" Size="Size.Small" Class="mr-1" /> @Oficina.vchTelefono
            </MudText>
        }

    </MudCardContent>

    <MudCardActions Style="padding: 1rem; margin-top: auto;">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="OnClickVer">Ver</MudButton>
        <MudButton Variant="Variant.Outlined" Style="border-color: #A50A3A; color: #A50A3A;" Class="ml-2" OnClick="OnClickEditar">Editar</MudButton>
        <MudSpacer />
        <MudButton Variant="Variant.Text" Color="Color.Error" OnClick="@(() => OnClickEliminar(Oficina))">Eliminar</MudButton>
    </MudCardActions>
</MudCard>

@code {
    [Parameter] public Oficina Oficina { get; set; }
    [Parameter] public EventCallback<Oficina> OnView { get; set; }
    [Parameter] public EventCallback<Oficina> OnEdit { get; set; }
    [Parameter] public EventCallback<Oficina> OnDelete { get; set; }
}
