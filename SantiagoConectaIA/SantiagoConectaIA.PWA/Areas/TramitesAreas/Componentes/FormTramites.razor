@inherits EngramaWorkspaceComponent
@using SantiagoConectaIA.PWA.Shared.Workspace
@using SantiagoConectaIA.Share.Objects.TramitesModule
@using SantiagoConectaIA.Share.Objects.OficinasModule
@inject ISnackbar Snackbar
@using System.ComponentModel.DataAnnotations

@using MudBlazor

<EditForm Model="@TramiteModel" OnValidSubmit="OnSubmit">
    <DataAnnotationsValidator />
    
    <MudCard>
        <MudCardContent>
            <MudTabs Elevation="2" Rounded="true" ApplyEffectsToContainer="true" PanelClass="pa-6">
                
                @* TABS 1: Información General *@
                <MudTabPanel Text="Información General" Icon="@Icons.Material.Filled.Info">
                    <MudGrid>
                        <MudItem xs="12" sm="6">
                            <MudTextField @bind-Value="TramiteModel.vchNombre" Label="Nombre del Trámite" MaxLength="50" Variant="Variant.Outlined" Class="mb-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                            <MudTextField @bind-Value="TramiteModel.nvchDescripcion" Label="Descripción del Trámite" Lines="3" MaxLength="500" Variant="Variant.Outlined" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                            <MudTextField @bind-Value="TramiteModel.vchNombreEn" Label="Nombre del Trámite (Inglés)" MaxLength="250" Variant="Variant.Outlined" Class="mb-4 mt-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                            <MudTextField @bind-Value="TramiteModel.nvchDescripcionEn" Label="Descripción del Trámite (Inglés)" Lines="3" MaxLength="500" Variant="Variant.Outlined" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                        </MudItem>

                        <MudItem xs="12" sm="6">
                            <MudGrid>
                                <MudItem xs="12" sm="6">
                                    <MudNumericField @bind-Value="TramiteModel.mCosto" Label="Costo" Variant="Variant.Outlined" Format="C2" Min="0" Class="mb-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura || TramiteModel.bPrecioCalculado)" />
                                </MudItem>

                                <MudItem xs="12" sm="6">
                                    <MudSwitch @bind-Value="TramiteModel.bPrecioCalculado" Color="Color.Warning" Label="Precio Calculado" Class="mt-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                                </MudItem>

                                <MudItem xs="12">
                                    <MudSelect @bind-Value="TramiteModel.iIdOficina" Label="Oficina Responsable" Variant="Variant.Outlined" AdornmentIcon="@Icons.Material.Filled.Business" Class="mb-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)">
                                        @if (Data?.LstOficinas != null)
                                        {
                                            @foreach (var oficina in Data.LstOficinas)
                                            {
                                                <MudSelectItem Value="oficina.iIdOficina">@oficina.vchNombre</MudSelectItem>
                                            }
                                        }
                                    </MudSelect>
                                </MudItem>

                                <MudItem xs="12" sm="6">
                                    <MudSwitch @bind-Value="TramiteModel.bModalidadEnLinea" Color="Color.Info" Label="Modalidad En Línea" Class="mt-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                                </MudItem>

                                <MudItem xs="12" sm="6">
                                    <MudSwitch @bind-Value="TramiteModel.bActivo" Color="Color.Success" Label="Trámite Activo" Class="mt-4" Disabled="@(EstadoControl == TipoEstadoControl.Lectura)" />
                                </MudItem>
                            </MudGrid>
                        </MudItem>
                    </MudGrid>
                </MudTabPanel>

                @* TABS 2: Requisitos *@
                <FormRequisito TramiteModel="TramiteModel" EstadoControl="EstadoControl" />
 
                @* TABS 3: Pasos a Seguir *@
                <FormPaso TramiteModel="TramiteModel" EstadoControl="EstadoControl" />
 
                @* TABS 4: Documentos *@
                <FormDocumento TramiteModel="TramiteModel" EstadoControl="EstadoControl" />

            </MudTabs>
        </MudCardContent>

    </MudCard>
</EditForm>