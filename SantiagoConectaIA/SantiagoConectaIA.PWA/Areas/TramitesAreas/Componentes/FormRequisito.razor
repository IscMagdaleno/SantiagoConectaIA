@using SantiagoConectaIA.Share.Objects.TramitesModule
@inherits EngramaComponent

<MudTabPanel Text="Requisitos" Icon="@Icons.Material.Filled.Checklist" Disabled="@(TramiteModel.iIdTramite <= 0)">
    <MudText Typo="Typo.subtitle1" Class="mb-4">Requisitos del Trámite</MudText>
    
    <div class="d-flex align-center gap-2 mb-4">
        <MudTextField @bind-Value="nuevoRequisito.vchNombre" Label="Nombre del Requisito" Variant="Variant.Outlined" MaxLength="250" />
        <MudTextField @bind-Value="nuevoRequisito.nvchDetalle" Label="Detalle (Opcional)" Variant="Variant.Outlined" />
        <MudSwitch @bind-Value="nuevoRequisito.bObligatorio" Color="Color.Error" Label="Obligatorio" />
        <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" OnClick="AgregarRequisito">Agregar</MudButton>
    </div>

    <MudTable Items="@TramiteModel.Requisitos" Hover="true" Dense="true" Elevation="0" CanCancelEdit="true" CommitEditTooltip="Guardar edición" CancelEditTooltip="Cancelar">
        <HeaderContent>
            <MudTh>Nombre</MudTh>
            <MudTh>Detalle</MudTh>
            <MudTh>Obligatorio</MudTh>
            <MudTh>Acciones</MudTh>
        </HeaderContent>
        <RowTemplate Context="req">
            <MudTd DataLabel="Nombre">@req.vchNombre</MudTd>
            <MudTd DataLabel="Detalle">@req.nvchDetalle</MudTd>
            <MudTd DataLabel="Obligatorio">
                <MudChip T="string" Color="@(req.bObligatorio ? Color.Error : Color.Info)" Size="Size.Small">
                    @(req.bObligatorio ? "Sí" : "No")
                </MudChip>
            </MudTd>
            <MudTd DataLabel="Acciones">
                <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small" OnClick="@(() => EliminarRequisito(req))" />
            </MudTd>
        </RowTemplate>
        <RowEditingTemplate Context="req">
            <MudTd DataLabel="Nombre">
                <MudTextField @bind-Value="req.vchNombre" Required="true" />
            </MudTd>
            <MudTd DataLabel="Detalle">
                <MudTextField @bind-Value="req.nvchDetalle" />
            </MudTd>
            <MudTd DataLabel="Obligatorio">
                <MudSwitch @bind-Value="req.bObligatorio" Color="Color.Error" />
            </MudTd>
        </RowEditingTemplate>
    </MudTable>
</MudTabPanel>
