@using MudBlazor
@inherits EngramaComponent



@if (Data == null)
{
	<MudAlert Severity="Severity.Info" Class="mb-4">Cargando datos del módulo...</MudAlert>
	return;
}

<MudCard Outlined="true" Class="mx-auto mt-4">
	<MudCardHeader>
		<CardHeaderContent>
			<MudText Typo="Typo.h5" Color="Color.Primary">
				<MudIcon Icon="@Icons.Material.Filled.SettingsApplications" Class="mr-2" />
				Configurador de Trámites
			</MudText>
			<MudText Typo="Typo.subtitle2">Complete la información general y configure los requisitos, pasos y documentos.</MudText>
		</CardHeaderContent>
	</MudCardHeader>

	<MudCardContent>
		<FormTramites Data="@Data" OnTramiteSaved="OnTramiteSaved" />
	</MudCardContent>
</MudCard>

