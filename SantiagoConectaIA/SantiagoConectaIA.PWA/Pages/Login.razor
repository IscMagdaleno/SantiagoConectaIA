@page "/login"
@attribute [Microsoft.AspNetCore.Authorization.AllowAnonymous]
@layout SantiagoConectaIA.PWA.Shared.EmptyLayout
@using SantiagoConectaIA.Share.PostModels.AuthModulo
@using SantiagoConectaIA.PWA.Helpers
@using Microsoft.AspNetCore.Components.Authorization
@using System.Net.Http.Json
@using MudBlazor
@inject HttpClient Http
@inject IJSRuntime JSRuntime
@inject AuthenticationStateProvider AuthStateProvider
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar

<PageTitle>Acceso | Santiago Conecta</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="d-flex align-center justify-center" Style="height: 100vh;">
    <div class="glass-premium animate-fade-in-up" style="width: 100%; max-width: 450px; padding: 2.5rem; border-radius: 24px;">
        <div class="text-center mb-6">
            <MudIcon Icon="Icons.Material.Filled.LocationCity" Size="Size.Large" Color="Color.Primary" Class="mb-2" Style="width: 64px; height: 64px;" />
            <MudText Typo="Typo.h4" Style="font-weight: 900; color: #1E293B; letter-spacing: -0.03em;">
                Santiago <span style="color: #A50A3A;">Conecta</span>
            </MudText>
            <MudText Typo="Typo.body2" Style="color: #64748B; margin-top: 8px;">
                Portal de Acceso Administrativo
            </MudText>
        </div>

        <EditForm Model="loginModel" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <MudTextField @bind-Value="loginModel.vchUserOrEmail" 
                          Label="Correo o Usuario" 
                          Variant="Variant.Outlined" 
                          InputType="InputType.Text" 
                          Required="true" 
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Person"
                          Class="mb-5 login-input" />

            <MudTextField @bind-Value="loginModel.vchPassword" 
                          Label="Contraseña" 
                          Variant="Variant.Outlined" 
                          InputType="InputType.Password" 
                          Required="true" 
                          Adornment="Adornment.Start"
                          AdornmentIcon="@Icons.Material.Filled.Lock"
                          Class="mb-6 login-input" />

            <MudButton ButtonType="ButtonType.Submit" 
                       Variant="Variant.Filled" 
                       Color="Color.Primary" 
                       FullWidth="true" 
                       Size="Size.Large"
                       Class="login-btn mt-2"
                       Style="border-radius: 12px; font-weight: bold; text-transform: none; font-size: 1.1rem; height: 56px;"
                       Disabled="isLoading">
                @if (isLoading)
                {
                    <MudProgressCircular Class="ms-n1" Size="Size.Small" Indeterminate="true" />
                    <MudText Class="ms-2">Verificando...</MudText>
                }
                else
                {
                    <MudText>Ingresar al Sistema</MudText>
                }
            </MudButton>
        </EditForm>
        
        <div class="text-center mt-6">
            <MudText Typo="Typo.caption" Style="color: #94A3B8;">
                &copy; @DateTime.Now.Year Municipio de Santiago Papasquiaro
            </MudText>
        </div>
    </div>
</MudContainer>

<style>
    .login-btn {
        box-shadow: 0 10px 25px -5px rgba(165, 10, 58, 0.4) !important;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    .login-btn:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 15px 30px -5px rgba(165, 10, 58, 0.5) !important;
    }
    .login-input .mud-input {
        border-radius: 12px;
        background-color: rgba(255, 255, 255, 0.8) !important;
    }
</style>

@code {
    private PostLoginUsuario loginModel = new PostLoginUsuario();
    private bool isLoading = false;

    private async Task HandleLogin()
    {
        isLoading = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/Auth/PostLoginUsuario", loginModel);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<Response<SantiagoConectaIA.Share.Objetos.AuthModulo.UsuarioAuth>>();
                if (result != null && result.IsSuccess)
                {
                    await JSRuntime.InvokeVoidAsync("localStorage.setItem", "authToken", result.Data.Token);
                    ((CustomAuthStateProvider)AuthStateProvider).NotifyUserAuthentication(result.Data.Token);
                    
                    NavigationManager.NavigateTo("/");
                    Snackbar.Add("Bienvenido(a) " + result.Data.vchNombre, Severity.Success);
                }
                else
                {
                    Snackbar.Add(result?.Message ?? "Credenciales incorrectas.", Severity.Error);
                }
            }
            else
            {
                Snackbar.Add("Error al comunicarse con el servidor.", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add("Ha ocurrido un error: " + ex.Message, Severity.Error);
        }
        finally
        {
            isLoading = false;
        }
    }
}
