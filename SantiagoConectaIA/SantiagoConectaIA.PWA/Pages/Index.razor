@page "/"
@inject SantiagoConectaIA.PWA.Shared.Workspace.WorkspaceService WorkspaceService

<PageTitle>Santiago Conecta | Portal Municipal</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-10 pb-16">
    <!-- Hero Section con Búsqueda Inteligente -->
    <div class="hero-minimal animate-fade-in-up">
        <MudText Typo="Typo.h2" Class="hero-title-main">
            Santiago Papasquiaro <span class="gradient-text">Conecta</span>
        </MudText>
        <MudText Typo="Typo.h6" Class="hero-subtitle-minimal">
            Panel centralizado para la administración y gestión de servicios digitales.
        </MudText>
    </div>

    <!-- Bento Grid Layout -->
    <div class="bento-grid mt-16">
        <!-- 2x2: Servicios Principales (Hero Card) -->
        <div class="bento-item bento-2x2 glass-premium animate-fade-in-up delay-1" @onclick="WorkspaceService.RequestTramites">
            <div class="bento-header">
                <MudChip T="string" Color="Color.Primary" Size="Size.Small" Variant="Variant.Text" Class="mb-2">Administración</MudChip>
                <MudText Typo="Typo.h4" Class="bento-title">Catálogo de Trámites</MudText>
                <MudText Typo="Typo.body1" Class="bento-desc-large">
                    Administra y registra nuevos trámites, así como sus requisitos y pasos a seguir.
                </MudText>
            </div>
            <div class="bento-illustration">
                <img src="city_services_illustration_1778873977467.png" alt="City Services" class="illustration-img" />
            </div>
            <div class="bento-footer">
                <MudButton EndIcon="@Icons.Material.Rounded.ArrowOutward" Color="Color.Primary" Class="px-0">Entrar al catálogo</MudButton>
            </div>
        </div>

        <!-- 2x1: Noticias Recientes -->
        <div class="bento-item bento-2x1 glass-premium animate-fade-in-up delay-2" @onclick="WorkspaceService.RequestNoticias">
            <div class="bento-header-flex">
                <div>
                    <MudText Typo="Typo.h5" Class="bento-title">Catálogo de Noticias</MudText>
                    <MudText Typo="Typo.body2" Class="bento-desc">Publica, edita y gestiona comunicados del municipio.</MudText>
                </div>
                <div class="icon-circle">
                    <MudIcon Icon="@Icons.Material.Rounded.Newspaper" />
                </div>
            </div>
            <div class="news-preview-list">
                <div class="news-item-mini">
                    <div class="news-dot"></div>
                    <MudText Typo="Typo.caption">Administración de publicaciones activas</MudText>
                </div>
                <div class="news-item-mini">
                    <div class="news-dot"></div>
                    <MudText Typo="Typo.caption">Control de historial y categorías</MudText>
                </div>
            </div>
        </div>

        <!-- 1x1: ChatBot IA -->
        <div class="bento-item bento-1x1 glass-premium animate-fade-in-up delay-3" @onclick="WorkspaceService.RequestChatbot">
            <div class="icon-wrapper-bento">
                <MudIcon Icon="@Icons.Material.Rounded.AutoAwesome" />
            </div>
            <div>
                <MudText Typo="Typo.h6" Class="bento-title">Gestión de IA</MudText>
                <MudText Typo="Typo.caption" Class="bento-desc">Configura comportamiento y respuestas.</MudText>
            </div>
            <div class="pulse-indicator"></div>
        </div>

        <!-- 1x1: Oficinas -->
        <div class="bento-item bento-1x1 glass-premium animate-fade-in-up delay-4" @onclick="WorkspaceService.RequestOficinas">
            <div class="icon-wrapper-bento secondary">
                <MudIcon Icon="@Icons.Material.Rounded.Map" />
            </div>
            <div>
                <MudText Typo="Typo.h6" Class="bento-title">Catálogo de Oficinas</MudText>
                <MudText Typo="Typo.caption" Class="bento-desc">Controla ubicaciones y contactos de dependencias.</MudText>
            </div>
        </div>


    </div>
</MudContainer>

<style>
    .hero-minimal {
        text-align: center;
        max-width: 800px;
        margin: 0 auto;
    }

    .hero-title-main {
        font-weight: 900 !important;
        letter-spacing: -0.05em;
        margin-bottom: 1rem;
        color: #1E293B;
    }

    .hero-subtitle-minimal {
        color: #64748B;
        font-weight: 400;
        opacity: 0.8;
    }

    /* Premium Search Bar */
    .search-container-premium {
        display: flex;
        align-items: center;
        padding: 8px 8px 8px 24px;
        border-radius: 100px;
        max-width: 650px;
        margin: 0 auto;
    }

    .search-input-field {
        flex-grow: 1;
    }

    .search-button-premium {
        border-radius: 100px !important;
        padding: 10px 32px !important;
        text-transform: none !important;
        font-weight: 600 !important;
        box-shadow: 0 8px 16px rgba(165, 10, 58, 0.2) !important;
    }

    /* Bento Item Specifics */
    .bento-header {
        margin-bottom: 1rem;
    }

    .bento-title {
        font-weight: 800 !important;
        letter-spacing: -0.02em;
        color: #1E293B;
    }

    .bento-desc-large {
        color: #64748B;
        line-height: 1.6;
        max-width: 80%;
    }

    .bento-illustration {
        position: absolute;
        bottom: 0;
        right: 0;
        width: 60%;
        height: 60%;
        display: flex;
        align-items: flex-end;
        justify-content: flex-end;
        pointer-events: none;
    }

    .illustration-img {
        max-width: 100%;
        max-height: 100%;
        object-fit: contain;
        transform: translate(10%, 10%);
        opacity: 0.9;
    }

    .bento-header-flex {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
    }

    .icon-circle {
        width: 48px;
        height: 48px;
        background: rgba(165, 10, 58, 0.1);
        color: var(--primary);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .news-preview-list {
        margin-top: auto;
    }

    .news-item-mini {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 4px;
        color: #64748B;
    }

    .news-dot {
        width: 6px;
        height: 6px;
        background: var(--primary);
        border-radius: 50%;
    }

    .icon-wrapper-bento {
        width: 56px;
        height: 56px;
        background: var(--primary);
        color: white;
        border-radius: 18px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1rem;
        box-shadow: 0 8px 16px rgba(165, 10, 58, 0.15);
    }

    .icon-wrapper-bento.secondary {
        background: #1E293B;
    }

    .pulse-indicator {
        position: absolute;
        top: 32px;
        right: 32px;
        width: 12px;
        height: 12px;
        background: #10B981;
        border-radius: 50%;
        animation: pulse-soft 2s infinite;
    }

    .stats-grid-bento {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
        margin-top: auto;
    }

    .stat-num {
        font-weight: 900 !important;
        color: var(--primary);
        letter-spacing: -0.03em;
    }

    .bento-item {
        cursor: pointer;
    }
</style>

@code {
    private string _searchQuery = "";

    private void HandleSearch()
    {
        // Implementación futura de búsqueda
    }
}