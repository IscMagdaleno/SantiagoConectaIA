@page "/"
@using SantiagoConectaFront.Data
@using SantiagoConectaIA.Share.PostModels.TramitesModule
@using Microsoft.Extensions.Localization
@inject NavigationManager NavManager
@inject IStringLocalizer<App> Localizer
@inject IJSRuntime JS

<PageTitle>Santiaguero Conecta - Inicio</PageTitle>

<!-- ***** Hero Section (Bienvenida) ***** -->
<div class="welcome-area" id="welcome" style="background-image: linear-gradient(135deg, rgba(136, 14, 79, 0.8), rgba(216, 27, 96, 0.9)), url('assets/images/banner-bg.jpg'); background-size: cover; background-position: center; min-height: 80vh; display: flex; align-items: center;">
    <div class="header-text" style="width: 100%;">
        <div class="container">
            <div class="row">
                <div class="col-xl-8 col-lg-10 col-md-12 col-sm-12 mx-auto text-center" style="margin-top: 80px;">
                    <h1 style="color: white; font-weight: 700; font-size: 3rem; margin-bottom: 20px;">Bienvenido a <span style="color: #ffb4a2;">Santiaguero Conecta</span></h1>
                    <p style="color: rgba(255, 255, 255, 0.9); font-size: 1.2rem; margin-bottom: 30px;">
                        Tu Asistente Virtual Inteligente 24/7. El H. Ayuntamiento de Santiago Papasquiaro pone a tu disposición esta herramienta para resolver tus dudas, consultar requisitos de trámites y evitar filas desde la comodidad de tu celular.
                    </p>
                    <button class="main-button-slider pulse-animation" @onclick="OpenChatbot" style="border: none; padding: 12px 30px; font-size: 1.1rem; font-weight: 600; border-radius: 30px; background-color: white; color: #880e4f; cursor: pointer; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
                        <i class="fa fa-comments mr-2"></i> Probar Chatbot Ahora
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>
<!-- ***** Hero Section End ***** -->

<!-- ***** Módulos Principales ***** -->
<section class="section home-feature" style="margin-top: -60px; position: relative; z-index: 10;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="row">
                    <!-- Trámites -->
                    <div class="col-lg-4 col-md-6 col-sm-6 col-12 mb-4" @onclick='() => NavManager.NavigateTo("/tramites", forceLoad: true)' style="cursor: pointer;">
                        <div class="features-small-item" style="border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s ease;">
                            <div class="icon" style="background: #fce4ec; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                <MudIcon Icon="@Icons.Material.Filled.Assignment" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <h5 class="features-title" style="color: #880e4f; font-weight: 700;">Catálogo de Trámites</h5>
                            <p>Consulta requisitos, costos y ubicaciones de los trámites municipales en un solo lugar y de forma transparente.</p>
                        </div>
                    </div>
                    <!-- Noticias -->
                    <div class="col-lg-4 col-md-6 col-sm-6 col-12 mb-4" @onclick='() => NavManager.NavigateTo("/noticias", forceLoad: true)' style="cursor: pointer;">
                        <div class="features-small-item" style="border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s ease;">
                            <div class="icon" style="background: #fce4ec; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                <MudIcon Icon="@Icons.Material.Filled.Article" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <h5 class="features-title" style="color: #880e4f; font-weight: 700;">Noticias y Avisos</h5>
                            <p>Mantente informado sobre los comunicados oficiales, eventos y noticias relevantes de Santiago Papasquiaro.</p>
                        </div>
                    </div>
                    <!-- Chatbot Info -->
                    <div class="col-lg-4 col-md-6 col-sm-6 col-12 mb-4" @onclick="OpenChatbot" style="cursor: pointer;">
                        <div class="features-small-item" style="border-radius: 16px; box-shadow: 0 10px 30px rgba(0,0,0,0.08); transition: transform 0.3s ease;">
                            <div class="icon" style="background: #fce4ec; width: 80px; height: 80px; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Color="Color.Primary" Size="Size.Large" />
                            </div>
                            <h5 class="features-title" style="color: #880e4f; font-weight: 700;">Inteligencia Artificial</h5>
                            <p>Nuestro chatbot responde al instante a tus preguntas mediante lenguaje natural. ¡Pruébalo ahora mismo!</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<!-- ***** Módulos End ***** -->

<!-- ***** Beneficios Section ***** -->
<section class="section padding-top-70 padding-bottom-0" id="beneficios">
    <div class="container">
        <div class="row">
            <div class="col-lg-5 col-md-12 col-sm-12 align-self-center">
                <!-- Usaremos un icono grande o imagen representativa -->
                <div style="background: linear-gradient(135deg, #fce4ec, #f8bbd0); border-radius: 20px; padding: 40px; text-align: center;">
                    <MudIcon Icon="@Icons.Material.Filled.PhonelinkRing" Style="font-size: 150px; color: #d81b60;" />
                </div>
            </div>
            <div class="col-lg-1"></div>
            <div class="col-lg-6 col-md-12 col-sm-12 align-self-center mobile-top-fix">
                <div class="left-heading">
                    <h2 class="section-title" style="color: #880e4f;">Cero Filas, Cero Complicaciones</h2>
                </div>
                <div class="left-text">
                    <p>En el H. Ayuntamiento de Santiago Papasquiaro estamos comprometidos con la modernización de la atención ciudadana. Con <strong>Santiaguero Conecta</strong>, la administración municipal está al alcance de tu mano.</p>
                    <ul style="list-style: none; padding-left: 0; margin-top: 20px;">
                        <li style="margin-bottom: 15px;"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Class="mr-2" /> <strong>Disponibilidad Total:</strong> Operativo 24 horas al día, 365 días al año.</li>
                        <li style="margin-bottom: 15px;"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Class="mr-2" /> <strong>Respuestas Inmediatas:</strong> Olvídate de los tiempos de espera telefónicos.</li>
                        <li style="margin-bottom: 15px;"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Class="mr-2" /> <strong>Lenguaje Natural:</strong> Pregunta como si hablaras con un humano.</li>
                        <li style="margin-bottom: 15px;"><MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Primary" Class="mr-2" /> <strong>Transparencia:</strong> Acceso equitativo a información actualizada de trámites.</li>
                    </ul>
                </div>
            </div>
        </div>
        <div class="row mt-5">
            <div class="col-lg-12">
                <div class="hr"></div>
            </div>
        </div>
    </div>
</section>
<!-- ***** Beneficios End ***** -->

<!-- ***** Contact Us (Buzón Ciudadano) ***** -->
<section class="section colored" id="contacto" style="background-color: #f8f9fa;">
    <div class="container">
        <div class="row">
            <div class="col-lg-12">
                <div class="center-heading">
                    <h2 class="section-title" style="color: #880e4f;">Buzón Ciudadano</h2>
                </div>
            </div>
            <div class="offset-lg-3 col-lg-6">
                <div class="center-text">
                    <p>Tu opinión es importante para nosotros. Utiliza este espacio para enviarnos tus comentarios, sugerencias o reportes directos al H. Ayuntamiento.</p>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-4 col-md-6 col-sm-12">
                <h5 class="margin-bottom-30" style="color: #880e4f;">Información de Contacto</h5>
                <div class="contact-text">
                    <p>
                        <strong>Dirección:</strong><br>
                        Calle Riva Palacio #19, Colonia Centro,<br>
                        Santiago Papasquiaro, Durango.
                    </p>
                    <p>
                        <strong>Teléfono Oficial:</strong><br>
                        674 86 2 18 46
                    </p>
                    <p><strong>Atención Ciudadana:</strong> Lunes a Viernes de 8:00 a 15:00 hrs.</p>
                </div>
            </div>
            <div class="col-lg-8 col-md-6 col-sm-12">
                <div class="contact-form" style="background: white; padding: 30px; border-radius: 16px; box-shadow: 0 5px 20px rgba(0,0,0,0.05);">
                    <EditForm Model="@contactModel" OnValidSubmit="HandleSubmit">
                        <DataAnnotationsValidator />
                        <div class="row">
                            <div class="col-lg-6 col-md-12 col-sm-12 mb-3">
                                <MudTextField @bind-Value="contactModel.Name" Label="Nombre Completo" Variant="Variant.Outlined" Required="true" />
                            </div>
                            <div class="col-lg-6 col-md-12 col-sm-12 mb-3">
                                <MudTextField @bind-Value="contactModel.Email" Label="Correo Electrónico" Variant="Variant.Outlined" Required="true" />
                            </div>
                            <div class="col-lg-12 mb-3">
                                <MudTextField @bind-Value="contactModel.Message" Label="Tu Mensaje, Queja o Sugerencia" Variant="Variant.Outlined" Lines="5" Required="true" />
                            </div>
                            <div class="col-lg-12">
                                <MudButton ButtonType="ButtonType.Submit" Variant="Variant.Filled" Color="Color.Primary" Size="Size.Large" FullWidth="true" Style="border-radius: 30px;">Enviar Mensaje</MudButton>
                            </div>
                        </div>
                    </EditForm>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .features-small-item:hover {
        transform: translateY(-10px);
        box-shadow: 0 15px 40px rgba(216, 27, 96, 0.2) !important;
    }
</style>

@code {
    private ContactModel contactModel = new();
    
    protected override async Task OnInitializedAsync()
    {
        // Inicialización ligera si es necesaria
    }

    private void HandleSubmit()
    {
        // TODO: Conectar a API de guardado de Buzón Ciudadano
        Console.WriteLine($"Mensaje recibido de {contactModel.Name}");
        contactModel = new(); // Reset
    }

    private async Task OpenChatbot()
    {
        try {
            // Buscamos específicamente el botón del Chatbot usando su contenedor
            // para evitar un loop infinito al hacer click en sí mismo.
            await JS.InvokeVoidAsync("eval", "document.querySelector('.chatbot-container .pulse-animation')?.click()");
        } catch { }
    }

    public class ContactModel
    {
        public string Name { get; set; } = string.Empty;
        public string Email { get; set; } = string.Empty;
        public string Message { get; set; } = string.Empty;
    }
}